        Tween(cardLogo,  {ImageTransparency=0}, 0.35)
        task.wait(0.08)
        Tween(cardTitle, {TextTransparency=0},  0.3)
        task.wait(0.06)
        Tween(cardSub,   {TextTransparency=0},  0.3)
        task.wait(0.06)
        Tween(divider,   {BackgroundTransparency=0}, 0.25)
        task.wait(0.04)
        -- Lang buttons
        for _, d in pairs(btnData) do
            Tween(d.frame, {BackgroundTransparency=0}, 0.28, Enum.EasingStyle.Back)
            Tween(d.flag,  {TextTransparency=0}, 0.28)
            Tween(d.label, {TextTransparency=0}, 0.28)
        end
        task.wait(0.1)
        Tween(confirmBtn, {BackgroundTransparency=0}, 0.28)
    end)

    -- ‚ĒÄ‚ĒÄ FIX: Synchronized fade-out ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    -- ALL elements fade out TOGETHER in one shot ‚ÄĒ no sequential disappearing
    local fired = false
    local function FireConfirm()
        if fired then return end
        fired = true
        rainbowConn:Disconnect()

        local FO = 0.32
        local FI = TweenInfo.new(FO, Enum.EasingStyle.Quart, Enum.EasingDirection.In)

        -- Everything fades at once
        local targets = {
            {card,       {BackgroundTransparency=1}},
            {ringBg,     {BackgroundTransparency=1}},
            {overlay,    {BackgroundTransparency=1}},
            {cardLogo,   {ImageTransparency=1}},
            {cardTitle,  {TextTransparency=1}},
            {cardSub,    {TextTransparency=1}},
            {divider,    {BackgroundTransparency=1}},
            {confirmBtn, {BackgroundTransparency=1, TextTransparency=1}},
        }
        for _, d in pairs(btnData) do
            table.insert(targets, {d.frame, {BackgroundTransparency=1}})
            table.insert(targets, {d.flag,  {TextTransparency=1}})
            table.insert(targets, {d.label, {TextTransparency=1}})
            table.insert(targets, {d.dot,   {BackgroundTransparency=1}})
        end

        -- Slight upward drift + fade
        Tween(card,   {Position=UDim2.new(0.5,0,0.46,0), BackgroundTransparency=1}, FO, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        Tween(ringBg, {Position=UDim2.new(0.5,0,0.46,0), BackgroundTransparency=1}, FO, Enum.EasingStyle.Quart, Enum.EasingDirection.In)

        for _, pair in ipairs(targets) do
            local obj, props = pair[1], pair[2]
            if obj and obj.Parent then
                TweenService:Create(obj, FI, props):Play()
            end
        end

        task.delay(FO + 0.06, function()
            if overlay  and overlay.Parent  then overlay:Destroy()   end
            if lsWrapper and lsWrapper.Parent then lsWrapper:Destroy() end
            if onDone then task.spawn(function() onDone(selectedLang) end) end
        end)
    end

    confirmBtn.MouseButton1Click:Connect(function()
        Ripple(confirmBtn)
        FireConfirm()
    end)
    -- Touch support
    confirmBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            FireConfirm()
        end
    end)
end

