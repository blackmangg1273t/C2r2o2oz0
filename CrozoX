function CrozoX:Notify(cfg)
    cfg=cfg or {}
    local title=cfg.Title or "Notification"
    local text =cfg.Text  or ""
    local dur  =cfg.Duration or 4
    local ntype=cfg.Type  or "Info"
    local T    =self._Theme
    local L    =self._Lang
    local xAlign=(L and L.IsRTL)
        and Enum.TextXAlignment.Right
        or  Enum.TextXAlignment.Left
    local typeMap={
        Success={color=T.Success,icon=Icons.checkcircle2,bg=T.NotifBgOk},
        Warning={color=T.Warning,icon=Icons.alerttriangle,bg=T.NotifBgWarn},
        Error  ={color=T.Error,  icon=Icons.xcircle,      bg=T.NotifBgErr},
        Info   ={color=T.Primary,icon=Icons.info,          bg=T.NotifBgInfo},
    }
    local td=typeMap[ntype] or typeMap.Info
    local color=td.color
    self._NotifCount=self._NotifCount+1
    local card=New("Frame",{Name="Notif_"..self._NotifCount,
        Size=UDim2.new(1,0,0,82),
        BackgroundColor3=T.Surface,BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=900,Parent=self._NotifContainer})
    Corner(card,13)
    Stroke(card,color,1,0.58)

    -- Coloured left panel
    local panel=New("Frame",{Size=UDim2.new(0,46,1,0),
        BackgroundColor3=td.bg,BorderSizePixel=0,ZIndex=901,Parent=card})
    New("UICorner",{CornerRadius=UDim.new(0,13),Parent=panel})
    New("Frame",{Size=UDim2.new(0,8,1,0),Position=UDim2.new(1,-8,0,0),
        BackgroundColor3=td.bg,BorderSizePixel=0,ZIndex=901,Parent=panel})
    local iconImg=Img(panel,td.icon,22,UDim2.new(0.5,-11,0.5,-11),color,903)
    iconImg.ImageTransparency=1

    local titleLbl=New("TextLabel",{Size=UDim2.new(1,-96,0,22),
        Position=UDim2.new(0,56,0,13),BackgroundTransparency=1,
        Text=title,TextColor3=T.Text,Font=FONTS.Bold,
        TextSize=14,  -- ‚Üź ō£ŔÉō®ōĪ
        TextXAlignment=xAlign,TextWrapped=false,
        TextTransparency=1,ZIndex=902,Parent=card})
    local bodyLbl=New("TextLabel",{Size=UDim2.new(1,-96,0,32),
        Position=UDim2.new(0,56,0,36),BackgroundTransparency=1,
        Text=text,TextColor3=T.TextDim,
        Font=L and L.FontBody or FONTS.Body,
        TextSize=L and L.LabelSize or 13,  -- ‚Üź ŔÖŔÜ ōßŔĄŔĄōļō©
        TextXAlignment=xAlign,TextWrapped=true,
        TextTransparency=1,ZIndex=902,Parent=card})

    -- Close X
    local xBtn=New("TextButton",{Size=UDim2.new(0,22,0,22),
        Position=UDim2.new(1,-28,0,8),BackgroundTransparency=1,
        Text="",ZIndex=904,Parent=card})
    local xIco=Img(xBtn,Icons.x,12,UDim2.new(0.5,-6,0.5,-6),T.TextMuted,905)
    xIco.ImageTransparency=1

    -- Progress
    local pbg=New("Frame",{Size=UDim2.new(1,-16,0,3),
        Position=UDim2.new(0,8,1,-7),BackgroundColor3=T.Border,
        BorderSizePixel=0,ZIndex=902,Parent=card})
    Corner(pbg,2)
    local pfill=New("Frame",{Size=UDim2.new(1,0,1,0),
        BackgroundColor3=color,BorderSizePixel=0,ZIndex=903,Parent=pbg})
    Corner(pfill,2)
    pfill.BackgroundTransparency=1

    -- Slide in + fade ALL simultaneously
    card.Position=UDim2.new(1,30,0,0)
    local FI=0.4
    Tween(card,{BackgroundTransparency=0,Position=UDim2.new(0,0,0,0)},FI,Enum.EasingStyle.Back)
    Tween(iconImg,{ImageTransparency=0},FI)
    Tween(titleLbl,{TextTransparency=0},FI)
    Tween(bodyLbl,{TextTransparency=0},FI)
    Tween(pfill,{BackgroundTransparency=0},FI)
    Tween(xIco,{ImageTransparency=0},FI)
    Tween(pfill,{Size=UDim2.new(0,0,1,0)},dur,Enum.EasingStyle.Linear)

    local dismissed=false
    local function Dismiss()
        if dismissed then return end; dismissed=true
        local FO=0.3
        Tween(card,{BackgroundTransparency=1,Position=UDim2.new(1,30,0,0)},FO,
            Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        Tween(iconImg,{ImageTransparency=1},FO)
        Tween(titleLbl,{TextTransparency=1},FO)
        Tween(bodyLbl,{TextTransparency=1},FO)
        Tween(pfill,{BackgroundTransparency=1},FO)
        Tween(xIco,{ImageTransparency=1},FO)
        task.delay(FO+0.05,function() card:Destroy() end)
    end
    task.delay(dur,Dismiss)
    xBtn.MouseButton1Click:Connect(Dismiss)
    local hov=New("TextButton",{Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,Text="",ZIndex=901,Parent=card})
    hov.MouseEnter:Connect(function()
        Tween(card,{BackgroundColor3=T.SurfaceAlt},0.15) end)
    hov.MouseLeave:Connect(function()
        Tween(card,{BackgroundColor3=T.Surface},0.15) end)
end

