    local loaderBg=New("Frame",{Size=UDim2.new(0,220,0,4),
        AnchorPoint=Vector2.new(0.5,0),Position=UDim2.new(0.5,0,0.5,186),
        BackgroundColor3=Color3.fromRGB(40,40,40),BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=104,Parent=bg})
    Corner(loaderBg,2)
    local loaderFill=New("Frame",{Size=UDim2.new(0,0,1,0),
        BackgroundColor3=CFG.GlowColor,BorderSizePixel=0,ZIndex=105,Parent=loaderBg})
    Corner(loaderFill,2)
    local particles={}
    local RADIUS=130
    for i=1,CFG.ParticleN do
        local angle=(i/CFG.ParticleN)*math.pi*2
        local sz=math.random(3,7)
        local dot=New("Frame",{Size=UDim2.new(0,sz,0,sz),
            AnchorPoint=Vector2.new(0.5,0.5),
            Position=UDim2.new(0.5+(RADIUS*math.cos(angle))/sg.AbsoluteSize.X,0,
                0.5+(RADIUS*math.sin(angle))/sg.AbsoluteSize.Y,-20),
            BackgroundColor3=(i%3==0) and CFG.AccentColor or CFG.GlowColor,
            BackgroundTransparency=1,BorderSizePixel=0,ZIndex=103,Parent=bg})
        Corner(dot,100)
        table.insert(particles,{dot=dot,angle=angle})
    end
    local startT=tick()
    local orbConn
    orbConn=RunService.RenderStepped:Connect(function()
        if not bg.Parent then orbConn:Disconnect();return end
        local t=tick()-startT
        local sw=sg.AbsoluteSize.X; local sh=sg.AbsoluteSize.Y
        if sw<=0 or sh<=0 then return end
        for i,p in ipairs(particles) do
            local speed=0.45+(i%3)*0.15
            local a=p.angle+t*speed
            local r=RADIUS+math.sin(t*1.8+i)*12
            p.dot.Position=UDim2.new(0.5+(r*math.cos(a))/sw,0,
                0.5+(r*math.sin(a))/sh,-20)
        end
    end)
    task.spawn(function()
        TweenWait(bg,{BackgroundTransparency=0.06},0.35,Enum.EasingStyle.Quad)
        Tween(glowOuter,{ImageTransparency=0.5},0.5)
        Tween(glowInner,{ImageTransparency=0.72},0.5)
        Tween(logoHolder,{Size=CFG.LogoEnd},CFG.ZoomDur,Enum.EasingStyle.Back)
        TweenWait(logoImg,{ImageTransparency=0},CFG.FadeIn)
        Tween(logoStroke,{Transparency=0.2},0.4)
        Tween(nameLabel,{TextTransparency=0},0.45)
        task.wait(0.12)
        Tween(tagLabel,{TextTransparency=0},0.4)
        Tween(line,{Size=UDim2.new(0,200,0,2)},0.5)
        Tween(loaderBg,{BackgroundTransparency=0},0.3)
        TweenWait(loaderFill,{Size=UDim2.new(1,0,1,0)},
            CFG.HoldDur*0.85,Enum.EasingStyle.Quart,Enum.EasingDirection.InOut)
        for i,p in ipairs(particles) do
            task.delay((i-1)*0.04,function()
                Tween(p.dot,{BackgroundTransparency=0.22},0.3) end)
        end
        for _=1,3 do
            Tween(logoHolder,{Size=CFG.LogoPulse},CFG.PulseDur*0.45,Enum.EasingStyle.Quad)
            Tween(logoStroke,{Transparency=0.04},CFG.PulseDur*0.45)
            Tween(glowOuter,{ImageTransparency=0.3},CFG.PulseDur*0.45)
            task.wait(CFG.PulseDur*0.45)
            Tween(logoHolder,{Size=CFG.LogoEnd},CFG.PulseDur*0.55,Enum.EasingStyle.Quad,Enum.EasingDirection.In)
            Tween(logoStroke,{Transparency=0.25},CFG.PulseDur*0.55)
            Tween(glowOuter,{ImageTransparency=0.52},CFG.PulseDur*0.55)
            task.wait(CFG.PulseDur*0.55)
        end
        for i,p in ipairs(particles) do
            local far=RADIUS*2.4
            task.delay((i-1)*0.018,function()
                Tween(p.dot,{
                    Position=UDim2.new(0.5+(far*math.cos(p.angle))/sg.AbsoluteSize.X,0,
                        0.5+(far*math.sin(p.angle))/sg.AbsoluteSize.Y,-20),
                    BackgroundTransparency=1,Size=UDim2.new(0,1,0,1),
                },CFG.FadeOut,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
            end)
        end
        task.wait(0.08)
        Tween(logoImg,{ImageTransparency=1},CFG.FadeOut)
        Tween(nameLabel,{TextTransparency=1},CFG.FadeOut)
        Tween(tagLabel,{TextTransparency=1},CFG.FadeOut)
        Tween(line,{BackgroundTransparency=1},CFG.FadeOut)
        Tween(loaderBg,{BackgroundTransparency=1},CFG.FadeOut)
        Tween(glowOuter,{ImageTransparency=1},CFG.FadeOut)
        Tween(glowInner,{ImageTransparency=1},CFG.FadeOut)
        Tween(logoHolder,{Size=UDim2.new(0,55,0,55)},CFG.FadeOut,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        TweenWait(bg,{BackgroundTransparency=1},CFG.FadeOut,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        orbConn:Disconnect()
        task.wait(0.08)
        bg:Destroy()
        if onDone then task.spawn(onDone) end
    end)
end

