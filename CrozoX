    resizeBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            -- PC: مباشر
            resizing = true; dragging = false
            local mp = UserInputService:GetMouseLocation()
            rStartX=mp.X; rStartY=mp.Y
            rW=wrapFrame.AbsoluteSize.X; rH=wrapFrame.AbsoluteSize.Y
            rPX=wrapFrame.Position.X.Offset; rPY=wrapFrame.Position.Y.Offset
            Tween(resizeBtn,{BackgroundColor3=T.Primary,BackgroundTransparency=0},0.1)

        elseif inp.UserInputType == Enum.UserInputType.Touch then
            holdActive = false
            if holdTimer then task.cancel(holdTimer); holdTimer=nil end
            Tween(resizeBtn,{BackgroundColor3=T.BorderBright,BackgroundTransparency=0},0.15)
            holdTimer = task.delay(0.35, function()
                -- Hold اكتمل → ابدأ resize من موضع الإصبع الحالي
                holdActive = true
                dragging   = false
                local mp2  = UserInputService:GetMouseLocation()
                rStartX = mp2.X
                rStartY = mp2.Y
                rW  = wrapFrame.AbsoluteSize.X
                rH  = wrapFrame.AbsoluteSize.Y
                rPX = wrapFrame.Position.X.Offset
                rPY = wrapFrame.Position.Y.Offset
                resizing = true
                Tween(resizeBtn,{BackgroundColor3=T.Primary,BackgroundTransparency=0},0.1)
            end)
        end
    end)

    -- الحركة والإنهاء عبر UserInputService
    -- عشان الـ resize يستمر حتى بعد إبعاد الإصبع عن الزر
    UserInputService.InputChanged:Connect(function(inp)
        if not (holdActive and resizing) then return end
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseMovement then
            local mp2  = UserInputService:GetMouseLocation()
            local newW = math.clamp(rW + (mp2.X - rStartX), MIN_W, MAX_W)
            local newH = math.clamp(rH + (mp2.Y - rStartY), MIN_H, MAX_H)
            wrapFrame.Size     = UDim2.new(0,newW,0,newH)
            wrapFrame.Position = UDim2.new(0,rPX,0,rPY)
            smoothX=rPX; smoothY=rPY; dispX=rPX; dispY=rPY
            size = UDim2.new(0,newW,0,newH)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch and holdActive then
            -- الإصبع رُفع → انتهى الـ resize
            if holdTimer then task.cancel(holdTimer); holdTimer=nil end
            holdActive = false
            resizing   = false
            Tween(resizeBtn,{BackgroundColor3=Color3.fromRGB(30,30,30),BackgroundTransparency=0.1},0.2)
        end
    end)
    resizeBtn.MouseEnter:Connect(function()
        if resizing then return end
