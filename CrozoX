        -- Slider
        function Tab:AddSlider(scfg)
            scfg = scfg or {}
            local name = scfg.Name or "Slider"
            local min  = scfg.Min  or 0
            local max  = scfg.Max  or 100
            local def  = math.clamp(scfg.Default or min, min, max)
            local suf  = scfg.Suffix or ""
            local cb   = scfg.Callback or function() end
            local val  = def
            local f = EF(62)
            EL(f, name, 12, 10, 200, 18, T.Text, L.FontSemi, 13)
            local vl = EL(f, tostring(val)..suf, 0, 10, 85, 18,
                T.Primary, Enum.Font.GothamBold, 13, 14, Enum.TextXAlignment.Right)
            vl.Position = UDim2.new(1,-96,0,10)
            vl.Size     = UDim2.new(0,84,0,18)

            local tbg = New("Frame", {
                Size=UDim2.new(1,-24,0,5),
                Position=UDim2.new(0,12,0,44),
                BackgroundColor3=T.Border,
                BorderSizePixel=0, ZIndex=14, Parent=f,
            })
            Corner(tbg, 3)
            local fill = New("Frame", {
                Size=UDim2.new((val-min)/(max-min),0,1,0),
                BackgroundColor3=T.Primary,
                BorderSizePixel=0, ZIndex=15, Parent=tbg,
            })
            Corner(fill, 3)
            local knob = New("Frame", {
                Size=UDim2.new(0,14,0,14),
                Position=UDim2.new((val-min)/(max-min),-7,0.5,-7),
                BackgroundColor3=Color3.new(1,1,1),
                BorderSizePixel=0, ZIndex=16, Parent=tbg,
            })
            Corner(knob, 7)
            Stroke(knob, T.BorderBright, 1, 0)

            local drag = false
            local cz = New("TextButton", {
                Size=UDim2.new(1,0,0,30),
                Position=UDim2.new(0,0,0,32),
                BackgroundTransparency=1, Text="", ZIndex=17, Parent=f,
            })
            cz.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
            end)
            cz.InputEnded:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
            end)
            local El = { Value=val }
            local function SV(v, fire)
                v=math.clamp(math.floor(v+0.5),min,max)
                val=v; El.Value=v
                local p=(v-min)/(max-min)
                Tween(fill, { Size=UDim2.new(p,0,1,0) }, 0.05)
                Tween(knob, { Position=UDim2.new(p,-7,0.5,-7) }, 0.05)
                vl.Text=tostring(v)..suf
                if fire~=false then Safe(cb,v) end
            end
            UserInputService.InputChanged:Connect(function(inp)
                if drag and inp.UserInputType==Enum.UserInputType.MouseMovement then
                    local p=math.clamp((inp.Position.X-tbg.AbsolutePosition.X)
                        /tbg.AbsoluteSize.X,0,1)
                    SV(min+p*(max-min))
                end
            end)
            function El:Set(v) SV(v,true) end
            function El:Get() return val end
            return El
        end

