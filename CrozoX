            local f=EF(64)
            EL(f,name,12,8,270,20,T.Text,L.FontSemi,FS.Button)
            local box=New("TextBox",{Size=UDim2.new(1,-24,0,28),
                Position=UDim2.new(0,12,0,30),BackgroundColor3=T.Background,
                Text=def,PlaceholderText=ph,PlaceholderColor3=T.TextMuted,
                TextColor3=T.Text,Font=L.FontBody,TextSize=FS.Button,
                BorderSizePixel=0,ClearTextOnFocus=false,
                TextXAlignment=L.IsRTL and Enum.TextXAlignment.Right or Enum.TextXAlignment.Left,
                ZIndex=14,Parent=f})
            Corner(box,8);Pad(box,0,0,10,10)
            local bs=Stroke(box,T.Border,1,0)
            box.Focused:Connect(function() Tween(bs,{Color=T.Primary},0.15) end)
            box.FocusLost:Connect(function(enter)
                Tween(bs,{Color=T.Border},0.15)
                if enter then Safe(cb,box.Text) end
            end)
            local El={}
            function El:Get() return box.Text end
            function El:Set(v) box.Text=v end
            return El
        end

        if isFirstTab then
            task.defer(function()
                task.wait()
                SelectTab()
            end)
        end

        return Tab
    end -- CreateTab

    local WAPI={}
    setmetatable(WAPI,{
        __call=function(_,tcfg)
            if type(tcfg)=="string" then tcfg={Name=tcfg} end
            return Window:CreateTab(tcfg)
        end,
        __index=Window,
    })
    function WAPI:CreateTab(c) return Window:CreateTab(c) end
    function WAPI:Toggle()
        if wrapFrame.Visible then
            Tween(mainFrame,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},0.3,
                Enum.EasingStyle.Quart,Enum.EasingDirection.In)
            task.delay(0.32,function() wrapFrame.Visible=false end)
        else
            wrapFrame.Visible=true
            mainFrame.Size=UDim2.new(0.88,0,0.88,0)
            Tween(mainFrame,{Size=UDim2.new(1,0,1,0),BackgroundTransparency=0},
                0.35,Enum.EasingStyle.Back)
        end
    end
    function WAPI:Destroy()
        DoClose()
    end
    table.insert(self._Windows,WAPI)
    return WAPI
end

-- ============================================================
--  FIX 3: NOTIFICATIONS ‚ÄĒ all elements dismiss as one block
--  ‚ú¶ card ō•ō∑ōßōĪ Ŕąōßō≠ōĮ Ŕäō™ō≠ōĪŔÉ ŔÉŔÉō™ŔĄō©
--  ‚ú¶ ŔĄōß Tween ŔÖŔÜŔĀōĶŔĄ ŔĄŔÉŔĄ ōĻŔÜōĶōĪ ‚ÄĒ ŔĀŔāō∑ card Ŕäō™ō≠ōĪŔÉ + ImageTransparency ŔĄŔĄō£ŔäŔāŔąŔÜō©
-- ============================================================
function CrozoX:Notify(cfg)
    cfg=cfg or {}
    local title=cfg.Title or "Notification"
    local text =cfg.Text  or ""
    local dur  =cfg.Duration or 4
    local ntype=cfg.Type  or "Info"
    local T    =self._Theme
    local L    =self._Lang
    local xAlign=(L and L.IsRTL)
        and Enum.TextXAlignment.Right
        or  Enum.TextXAlignment.Left
    local typeMap={
        Success={color=T.Success,icon=Icons.checkcircle2,bg=T.NotifBgOk},
        Warning={color=T.Warning,icon=Icons.alerttriangle,bg=T.NotifBgWarn},
        Error  ={color=T.Error,  icon=Icons.xcircle,      bg=T.NotifBgErr},
        Info   ={color=T.Primary,icon=Icons.info,          bg=T.NotifBgInfo},
    }
    local td=typeMap[ntype] or typeMap.Info
    local color=td.color
    self._NotifCount=self._NotifCount+1

    local _nCam   = workspace.CurrentCamera
    local _nVP    = _nCam and _nCam.ViewportSize or Vector2.new(800,600)
    local _nMin   = math.min(_nVP.X, _nVP.Y)
    local isMob   = (Device.IsMobile or Device.IsTablet) or (_nMin < 500)
    local cardH   = isMob and 72  or 82
    local panelW  = isMob and 38  or 46
    local iconSz  = isMob and 18  or 22
    local titleSz = 14
    local bodySz  = isMob and 12  or (L and L.LabelSize or 13)
    local titleY  = isMob and 10  or 13
    local bodyY   = isMob and 30  or 36
    local bodyH   = isMob and 26  or 32
    local txtOffX = isMob and (panelW+8) or 56
    local xBtnSz  = isMob and 20 or 24

    -- FIX 3: Single card frame ‚ÄĒ everything inside moves as ONE block
    -- Use GroupTransparency approach: set card BackgroundTransparency + all labels at same tick
    local card=New("Frame",{Name="Notif_"..self._NotifCount,
        Size=UDim2.new(1,0,0,cardH),
        BackgroundColor3=T.Surface,BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=900,Parent=self._NotifContainer})
    Corner(card, isMob and 9 or 13)

    -- Store all tweenables in a list for simultaneous dismiss
    local allTweenables = {}

    local notifStroke = Stroke(card,color,1,0.5)
    table.insert(allTweenables,{obj=notifStroke, hide={Transparency=1}})

    local panel=New("Frame",{Size=UDim2.new(0,panelW,1,0),
        BackgroundColor3=td.bg,BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=901,Parent=card})
    New("UICorner",{CornerRadius=UDim.new(0, isMob and 9 or 13),Parent=panel})
    New("Frame",{Size=UDim2.new(0,8,1,0),Position=UDim2.new(1,-8,0,0),
        BackgroundColor3=td.bg,BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=901,Parent=panel})
    table.insert(allTweenables,{obj=panel, hide={BackgroundTransparency=1},
        show={BackgroundTransparency=0}})

    local iconImg=Img(panel,td.icon or "",iconSz,
        UDim2.new(0.5,-iconSz/2,0.5,-iconSz/2),color,903)
    iconImg.ImageTransparency=1
    table.insert(allTweenables,{obj=iconImg, hide={ImageTransparency=1},
        show={ImageTransparency=0}})

    local titleLbl=New("TextLabel",{
        Size=UDim2.new(1,-(txtOffX+36),0,18),
        Position=UDim2.new(0,txtOffX,0,titleY),
        BackgroundTransparency=1,Text=title,TextColor3=T.Text,
        Font=FONTS.Bold,TextSize=titleSz,
        TextXAlignment=xAlign,TextWrapped=false,
        TextTruncate=Enum.TextTruncate.AtEnd,
        TextTransparency=1,ZIndex=902,Parent=card})
    table.insert(allTweenables,{obj=titleLbl, hide={TextTransparency=1},
        show={TextTransparency=0}})

    local bodyLbl=New("TextLabel",{
        Size=UDim2.new(1,-(txtOffX+36),0,bodyH),
        Position=UDim2.new(0,txtOffX,0,bodyY),
        BackgroundTransparency=1,Text=text,TextColor3=T.TextDim,
        Font=L and L.FontBody or FONTS.Body,
        TextSize=bodySz,TextXAlignment=xAlign,TextWrapped=true,
        TextTransparency=1,ZIndex=902,Parent=card})
    table.insert(allTweenables,{obj=bodyLbl, hide={TextTransparency=1},
        show={TextTransparency=0}})

    local xBtn=New("TextButton",{Size=UDim2.new(0,xBtnSz,0,xBtnSz),
        Position=UDim2.new(1,-(xBtnSz+5),0,5),
        BackgroundColor3=Color3.fromRGB(40,40,40),
        BackgroundTransparency=isMob and 0.2 or 1,
        Text="",ZIndex=904,Parent=card})
    if isMob then Corner(xBtn, 5) end
    table.insert(allTweenables,{obj=xBtn, hide={BackgroundTransparency=1},
        show={BackgroundTransparency=isMob and 0.2 or 1}})

    local xIcoSz = isMob and 10 or 12
    local xIco=Img(xBtn,Icons.x,xIcoSz,
        UDim2.new(0.5,-xIcoSz/2,0.5,-xIcoSz/2),T.TextMuted,905)
    xIco.ImageTransparency=1
    table.insert(allTweenables,{obj=xIco, hide={ImageTransparency=1},
        show={ImageTransparency=0}})

    local pbg=New("Frame",{Size=UDim2.new(1,-12,0,2),
        Position=UDim2.new(0,6,1,-5),BackgroundColor3=T.Border,
        BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=902,Parent=card})
    Corner(pbg,1)
    table.insert(allTweenables,{obj=pbg, hide={BackgroundTransparency=1},
        show={BackgroundTransparency=0}})

    local pfill=New("Frame",{Size=UDim2.new(1,0,1,0),
        BackgroundColor3=color,BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=903,Parent=pbg})
    Corner(pfill,1)
    table.insert(allTweenables,{obj=pfill, hide={BackgroundTransparency=1},
        show={BackgroundTransparency=0}})

    -- Slide in from right
    local FI = 0.32
    card.Position = UDim2.new(1, 30, 0, 0)
    -- FIX 3: Fade IN all elements simultaneously
    Tween(card,{BackgroundTransparency=0,Position=UDim2.new(0,0,0,0)},FI,Enum.EasingStyle.Back)
    for _,t in ipairs(allTweenables) do
        if t.show then Tween(t.obj, t.show, FI) end
    end
    -- Start progress bar
    task.delay(FI*0.8, function()
        if pfill and pfill.Parent then
            Tween(pfill,{Size=UDim2.new(0,0,1,0)},dur,Enum.EasingStyle.Linear)
        end
    end)

    local dismissed=false
    local function Dismiss()
        if dismissed then return end; dismissed=true
        local FO = 0.22
        -- FIX 3: ALL elements fade simultaneously as ONE block
        -- Single tween on card (position+transparency) + simultaneously all children
        Tween(card,{
            BackgroundTransparency=1,
            Position=UDim2.new(1,30,0,0)
        },FO,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        -- All tweenables at exact same time
        for _,t in ipairs(allTweenables) do
            Tween(t.obj, t.hide, FO, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        end
        task.delay(FO+0.05,function()
            if card and card.Parent then card:Destroy() end
        end)
    end

    task.delay(dur, Dismiss)
    xBtn.MouseButton1Click:Connect(Dismiss)
    xBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then Dismiss() end
    end)
end

