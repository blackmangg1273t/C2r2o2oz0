        Tween(iconH,{BackgroundColor3=Color3.new(1,1,1)},0.15)
        Tween(iconV,{BackgroundColor3=Color3.new(1,1,1)},0.15)
    end)
    resizeBtn.MouseLeave:Connect(function()
        if resizing then return end
        Tween(resizeBtn,{BackgroundColor3=Color3.fromRGB(30,30,30),BackgroundTransparency=0.1},0.15)
    end)

    -- ── RenderStepped: drag + resize + resize button pos ──
    local smoothX = 0   -- الموضع الحقيقي (بدون smooth)
    local smoothY = 0
    local dispX   = 0   -- الموضع المعروض (مع smooth)
    local dispY   = 0
    local smoothInit = false

    RunService.RenderStepped:Connect(function()
        if not wrapFrame.Parent then return end

        -- Touch drag بيتعمل في InputChanged مباشرةً — مش هنا
        -- هنا بس الـ Mouse drag (PC)
        local mp = UserInputService:GetMouseLocation()

        -- 1. Mouse Drag بـ DELTA + SMOOTH (PC فقط)
        if dragging then
            local dx = mp.X - lastMouseX
            local dy = mp.Y - lastMouseY
            smoothX = smoothX + dx
            smoothY = smoothY + dy
            lastMouseX = mp.X
            lastMouseY = mp.Y
        end

        -- تهيئة dispX/dispY أول مرة
        if not smoothInit then
            smoothInit = true
            smoothX = wrapFrame.Position.X.Offset
            smoothY = wrapFrame.Position.Y.Offset
            dispX   = smoothX
            dispY   = smoothY
        end

        -- Lerp سلس نحو الهدف
        if dragging or math.abs(dispX - smoothX) > 0.5 or math.abs(dispY - smoothY) > 0.5 then
            dispX = dispX + (smoothX - dispX) * 0.25
            dispY = dispY + (smoothY - dispY) * 0.25
            wrapFrame.Position = UDim2.new(0, dispX, 0, dispY)
        end

        -- 2. Resize بـ Position.Offset
        if resizing then
            local newW = math.clamp(rW + (mp.X - rStartX), MIN_W, MAX_W)
            local newH = math.clamp(rH + (mp.Y - rStartY), MIN_H, MAX_H)
            wrapFrame.Size     = UDim2.new(0, newW, 0, newH)
            wrapFrame.Position = UDim2.new(0, rPX,  0, rPY)
            -- sync smooth vars عشان drag بعد resize ما يقفز
            smoothX = rPX
            smoothY = rPY
            dispX   = rPX
            dispY   = rPY
            size    = UDim2.new(0, newW, 0, newH)
        end

        -- resizeBtn يتحرك تلقائياً مع wrapFrame (child منه)
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and resizing then
            resizing = false
            Tween(resizeBtn, {
                BackgroundColor3       = Color3.fromRGB(40, 40, 40),
                BackgroundTransparency = 0.2,
            }, 0.15)
        end
    end)

    -- ── Open animation — الحل النهائي ──────────────────────
    -- wrapFrame Position لا تتغير أبداً
    -- Animation على mainFrame Scale فقط
    mainFrame.BackgroundTransparency = 1

    task.defer(function()
        if not sg.Parent then return end
        local sw = sg.AbsoluteSize.X
        local sh = sg.AbsoluteSize.Y

        local baseW = size.X.Offset   -- 660 (base PC size)
        local baseH = size.Y.Offset   -- 470

        -- CalcLayout يرجع: visualW, visualH, scaleVal
        -- visualW/H = الحجم الفعلي المعروض على الشاشة
        -- scaleVal  = الـ UIScale المطبّق على wrapFrame
        local visualW, visualH, scaleVal = Device.CalcLayout(baseW, baseH)

        -- wrapFrame Size = base size دايماً (UIScale هو اللي يكبّره)
        wrapFrame.Size = UDim2.new(0, baseW, 0, baseH)

        -- Position بناءً على الـ visual size (مش base size!)
        -- ده هو الخطأ في v38 — كان بيحسب بـ base بدل visual
        wrapFrame.Position = UDim2.new(
            0, math.floor((sw - visualW) / 2),
            0, math.floor((sh - visualH) / 2)
        )

        -- طبّق UIScale على wrapFrame
        local existing = wrapFrame:FindFirstChildWhichIsA("UIScale")
        if existing then existing:Destroy() end
        if scaleVal ~= 1 then
            New("UIScale", { Scale = scaleVal, Parent = wrapFrame })
        end

        -- resizeBtn موجود دايماً — PC وموبايل
        -- الـ hold-to-resize على موبايل اتعمل فوق عند التعريف

        -- Animation على mainFrame فقط
        mainFrame.Size = UDim2.new(0.88, 0, 0.88, 0)
        Tween(mainFrame, {
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 0,
        }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)

    -- ── Close / Minimize ───────────────────────────────────
    local isMin = false

    local function DoClose()
        Tween(mainFrame, {
            Size                   = UDim2.new(0.9, 0, 0.9, 0),
            BackgroundTransparency = 1,
        }, 0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        Tween(shadowImg, {ImageTransparency = 1}, 0.25)
        task.delay(0.32, function()
            wrapFrame:Destroy()
        end)
    end

    local function DoMinimize()
        isMin = not isMin
        if isMin then
            Tween(mainFrame, {Size = UDim2.new(1, 0, 0, 54)}, 0.3)
            Tween(shadowImg, {ImageTransparency = 1}, 0.2)
            if Device.IsPC then
                Tween(resizeBtn,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},0.2,Enum.EasingStyle.Quart)
                task.delay(0.2,function()
                    if resizeBtn and resizeBtn.Parent then resizeBtn.Visible=false end
                end)
            else
                Tween(resizeBtn,{BackgroundTransparency=0.7},0.2)
            end
        else
            Tween(mainFrame, {Size = UDim2.new(1, 0, 1, 0)}, 0.35, Enum.EasingStyle.Back)
            Tween(shadowImg, {ImageTransparency = 0.55}, 0.35)
            if Device.IsPC then
                resizeBtn.Visible = true
                resizeBtn.Size    = UDim2.new(0, 0, 0, 0)
                Tween(resizeBtn,{Size=UDim2.new(0,22,0,22),BackgroundTransparency=0.1},0.3,Enum.EasingStyle.Back)
            else
                Tween(resizeBtn,{BackgroundTransparency=0.3},0.2)
            end
        end
    end

    -- ربط الأحداث
    -- المشكلة في v43: InputBegan (press-down) + MouseButton1Click (press-up)
    -- = DoMinimize بيشتغل مرتين → toggle مرتين → يرجع للحالة الأولى
    -- الحل: على موبايل نستخدم InputEnded فقط (رفع الإصبع = tap مكتمل)
    -- ونمنع MouseButton1Click من التشغيل على موبايل عشان مش double-fire
    local function ConnectBtn(btn, fn)
        if Device.IsPC then
            btn.MouseButton1Click:Connect(fn)
        else
            -- موبايل: InputBegan + InputEnded على نفس الزر
            -- resizeBtn منفصل في sg فلا يوجد bubble
            local pressing = false
            btn.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.Touch then
                    pressing = true
                end
            end)
            btn.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.Touch and pressing then
                    pressing = false
                    fn()
                end
            end)
        end
    end
    ConnectBtn(closeBtn, DoClose)
    ConnectBtn(minBtn,   DoMinimize)

