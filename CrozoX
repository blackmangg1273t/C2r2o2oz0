-- Ripple
local function Ripple(button)
    local ripple = Create("Frame", {
        Size            = UDim2.new(0, 0, 0, 0),
        AnchorPoint     = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.75,
        BorderSizePixel = 0,
        ZIndex          = button.ZIndex + 5,
        Parent          = button,
    })
    RoundCorner(ripple, 100)
    local mp  = button.AbsolutePosition
    local ms  = button.AbsoluteSize
    ripple.Position = UDim2.new(0, Mouse.X - mp.X, 0, Mouse.Y - mp.Y)
    local size = math.max(ms.X, ms.Y) * 2.8
    Tween(ripple, { Size = UDim2.new(0, size, 0, size), BackgroundTransparency = 1 }, 0.5)
    game:GetService("Debris"):AddItem(ripple, 0.55)
end

local function SafeCall(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then warn("[CrozoX] " .. tostring(err)) end
    return ok, err
end

local ConfigCache = {}
local function SaveConfig(name, data)
    ConfigCache[name] = data
    if writefile then
        SafeCall(function()
            writefile("CrozoX_" .. name .. ".json",
                game:GetService("HttpService"):JSONEncode(data))
        end)
    end
end
local function LoadConfig(name)
    if ConfigCache[name] then return ConfigCache[name] end
    if readfile and isfile then
        local path = "CrozoX_" .. name .. ".json"
        if pcall(function() return isfile(path) end) then
            local ok, raw = SafeCall(readfile, path)
            if ok and raw then
                local ok2, decoded = SafeCall(function()
                    return game:GetService("HttpService"):JSONDecode(raw)
                end)
                if ok2 then return decoded end
            end
        end
    end
    return {}
end

