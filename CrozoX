--  DEVICE DETECTION
-- ============================================================
local Device = {}
do
    local cam = workspace.CurrentCamera
    local vp  = cam and cam.ViewportSize or Vector2.new(800, 600)
    local sw, sh = vp.X, vp.Y
    local minDim = math.min(sw, sh)
    Device.IsPC     = minDim >= 700
    Device.IsTablet = minDim >= 500 and minDim < 700
    Device.IsMobile = minDim < 500
    local UIS = UserInputService
    if UIS.TouchEnabled and not UIS.KeyboardEnabled then
        Device.IsPC     = false
        Device.IsTablet = false
        Device.IsMobile = true
    end
    function Device.CalcLayout(baseW, baseH)
        local fillW, fillH
        if Device.IsPC then
            return baseW, baseH, 1.0
        elseif Device.IsMobile then
            fillW = sw * 0.92
            fillH = sh * 0.88
        else
            fillW = sw * 0.88
            fillH = sh * 0.84
        end
        local scaleByW = fillW / baseW
        local scaleByH = fillH / baseH
        local scale    = math.min(scaleByW, scaleByH)
        scale = math.clamp(scale, 0.4, 3.0)
        local visualW = math.floor(baseW * scale)
        local visualH = math.floor(baseH * scale)
        return visualW, visualH, scale
    end
end

