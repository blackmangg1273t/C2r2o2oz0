                end
            end)
        end
    end

    -- FIX 5F: Unified button connection ‚ÄĒ same for PC and mobile
    local function ConnectBtn(btn, fn)
        local pressing = false
        -- PC click
        btn.MouseButton1Click:Connect(function()
            fn()
        end)
        -- Mobile touch ‚ÄĒ only fires on InputEnded to avoid double-fire with MouseButton1Click
        -- Use a guard: on mobile MouseButton1Click doesn't fire, so no conflict
        if Device.IsMobile or Device.IsTablet then
            btn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.Touch then
                    pressing = true
                end
            end)
            btn.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.Touch and pressing then
                    pressing = false
                    fn()
                end
            end)
        end
    end
