        Text                 = title,
        TextColor3           = T.Text,
        Font                 = Enum.Font.GothamBlack,
        TextSize             = 15,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 12,
        Parent               = titleBar,
    })

    Create("TextLabel", {
        Size                 = UDim2.new(0, 180, 0, 16),
        Position             = UDim2.new(0, 48, 0, 30),
        BackgroundTransparency = 1,
        Text                 = subtitle,
        TextColor3           = T.TextMuted,
        Font                 = Enum.Font.Gotham,
        TextSize             = 10,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 12,
        Parent               = titleBar,
    })

    -- ── Control buttons (Close + Minimize) ───────────────────
    local function CtrlBtn(iconAsset, xOff, hoverColor)
        local btn = Create("Frame", {
            Size                 = UDim2.new(0, 30, 0, 30),
            Position             = UDim2.new(1, xOff, 0.5, -15),
            BackgroundColor3     = T.SurfaceAlt,
            BorderSizePixel      = 0,
            ZIndex               = 13,
            Parent               = titleBar,
        })
        RoundCorner(btn, 8)
        Create("UIStroke", { Color = T.Border, Thickness = 1, Parent = btn })

        local icon = MakeIcon(btn, iconAsset, 14,
            UDim2.new(0.5, -7, 0.5, -7), T.TextDim, 14)

        local clickBtn = Create("TextButton", {
            Size                 = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                 = "",
            ZIndex               = 15,
            Parent               = btn,
        })
        clickBtn.MouseEnter:Connect(function()
            Tween(btn,  { BackgroundColor3 = hoverColor }, 0.15)
            Tween(icon, { ImageColor3 = Color3.fromRGB(255, 255, 255) }, 0.15)
        end)
        clickBtn.MouseLeave:Connect(function()
            Tween(btn,  { BackgroundColor3 = T.SurfaceAlt }, 0.15)
            Tween(icon, { ImageColor3 = T.TextDim          }, 0.15)
        end)
        return clickBtn, btn, icon
    end

    local closeClick, closeFrame, closeIcon   = CtrlBtn(Icons.x,     -10, Color3.fromRGB(220, 38, 38))
    local minClick,   minFrame,   minIcon     = CtrlBtn(Icons.minus,  -48, T.SurfaceHover)

    -- ── Sidebar ──────────────────────────────────────────────
    local sidebar = Create("Frame", {
        Name                 = "Sidebar",
        Size                 = UDim2.new(0, 150, 1, -52),
