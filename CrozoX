    task.spawn(function()
        repeat task.wait() until LocalPlayer and LocalPlayer.UserId ~= 0
        local userId = LocalPlayer.UserId

        -- rbxthumb فوري كـ fallback — يظهر فوراً حتى لو الـ async اتعلق
        avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. userId .. "&w=150&h=150"

        -- GetUserThumbnailAsync في coroutine منفصلة مع timeout 3 ثواني
        -- عشان لو اتعلق، منفضلش في الـ loop للأبد
        local betterUrl = nil
        local fetchDone = false

        task.spawn(function()
            local ok, content = pcall(function()
                return Players:GetUserThumbnailAsync(
                    userId,
                    Enum.ThumbnailType.HeadShot,
                    Enum.ThumbnailSize.Size420x420
                )
            end)
            if ok and content and content ~= "" then
                betterUrl = content
            end
            fetchDone = true
        end)

        -- انتظر الـ fetch بحد أقصى 3 ثواني
        local waited = 0
        while not fetchDone and waited < 3 do
            task.wait(0.1)
            waited = waited + 0.1
        end

        -- لو جاب جودة أعلى، استخدمها
        if betterUrl then
            avatarImg.Image = betterUrl
