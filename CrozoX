    -- CtrlBtn يرجع الـ TextButton
    -- على موبايل نستخدم InputBegan Touch بدل TouchTap (أكثر موثوقية)
    local function CtrlBtn(iconAsset, rightOff, normalBg, hoverBg, iconColor)
        local mobOff = Device.IsPC and rightOff or (rightOff * (_btnSz / 28))
        local fr = New("Frame", {
            Size             = UDim2.new(0, _btnSz, 0, _btnSz),
            AnchorPoint      = Vector2.new(1, 0.5),
            Position         = UDim2.new(1, -mobOff, 0.5, 0),
            BackgroundColor3 = normalBg,
            BorderSizePixel  = 0,
            ZIndex           = 20,
            Parent           = titleBar,
        })
        Corner(fr, _btnCorner)
        Stroke(fr, Color3.fromRGB(255,255,255), 1, 0.88)
        local icon = New("ImageLabel", {
            Size=UDim2.new(0,_btnIcoSz,0,_btnIcoSz),
            AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,0,0.5,0),
            BackgroundTransparency=1, Image=iconAsset, ImageColor3=iconColor,
            ScaleType=Enum.ScaleType.Fit, ZIndex=21, Parent=fr,
        })
        local btn = New("TextButton", {
            Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
            Text="", ZIndex=22, Parent=fr,
        })
        local normSz  = UDim2.new(0,_btnSz,  0,_btnSz)
        local pressSz = UDim2.new(0,_btnSz-4,0,_btnSz-4)
        -- PC: hover + click
        btn.MouseEnter:Connect(function()
            Tween(fr,{BackgroundColor3=hoverBg},0.15)
            Tween(icon,{ImageColor3=Color3.new(1,1,1)},0.15)
            Tween(fr,{Size=UDim2.new(0,_btnSz+2,0,_btnSz+2)},0.12,Enum.EasingStyle.Back)
        end)
        btn.MouseLeave:Connect(function()
            Tween(fr,{BackgroundColor3=normalBg},0.15)
            Tween(icon,{ImageColor3=iconColor},0.15)
            Tween(fr,{Size=normSz},0.12)
        end)
        btn.MouseButton1Down:Connect(function() Tween(fr,{Size=pressSz},0.08) end)
        btn.MouseButton1Up:Connect(function()   Tween(fr,{Size=normSz},0.12,Enum.EasingStyle.Back) end)
        -- موبايل: InputBegan = visual feedback فقط (مش action)
        -- الـ action بيتشغل من ConnectBtn بـ InputEnded
        btn.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch then
                Tween(fr,{BackgroundColor3=hoverBg,Size=pressSz},0.08)
            end
        end)
        btn.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch then
                Tween(fr,{BackgroundColor3=normalBg,Size=normSz},0.15,Enum.EasingStyle.Back)
            end
        end)
        return btn
    end

