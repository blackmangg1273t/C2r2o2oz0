                    rb.MouseEnter:Connect(function()
                        if o~=sel then Tween(row, { BackgroundColor3=T.SurfaceHover }, 0.1) end
                    end)
                    rb.MouseLeave:Connect(function()
                        if o~=sel then Tween(row, { BackgroundColor3=T.SurfaceAlt }, 0.1) end
                    end)
                    rb.MouseButton1Click:Connect(function()
                        SetSel(o); open=false
                        Tween(dl, { Size=UDim2.new(1,0,0,0) }, 0.2)
                        Tween(aIco, { Rotation=0 }, 0.2)
                        task.delay(0.22, function() dl.Visible=false end)
                    end)
                end
            end
            Refresh()
            local tog = New("TextButton", {
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1, Text="", ZIndex=15, Parent=f,
            })
            tog.MouseButton1Click:Connect(function()
                open=not open
                if open then
                    Refresh(); dl.Visible=true
                    local th=math.min(#opts*30+8,180)
                    Tween(dl, { Size=UDim2.new(1,0,0,th) }, 0.25, Enum.EasingStyle.Back)
                    Tween(aIco, { Rotation=180 }, 0.2)
                else
                    Tween(dl, { Size=UDim2.new(1,0,0,0) }, 0.2)
                    Tween(aIco, { Rotation=0 }, 0.2)
                    task.delay(0.22, function() dl.Visible=false end)
                end
            end)
            function El:Set(v) SetSel(v) end
            function El:Get() return sel end
            function El:SetOptions(o) opts=o; Refresh() end
            return El
        end

        -- Keybind
        function Tab:AddKeybind(kcfg)
            kcfg = kcfg or {}
            local name = kcfg.Name    or "Keybind"
            local def  = kcfg.Default or Enum.KeyCode.RightControl
            local cb   = kcfg.Callback or function() end
            local cur  = def; local listen = false
            local f = EF(42)
            EL(f, name, 12, 12, 220, 18, T.Text, L.FontSemi, 13)
            local kb = New("TextButton", {
                Size=UDim2.new(0,96,0,26),
                Position=UDim2.new(1,-108,0.5,-13),
                BackgroundColor3=T.Background,
                Text=cur.Name, TextColor3=T.Primary,
                Font=Enum.Font.GothamBold, TextSize=11,
                BorderSizePixel=0, ZIndex=14, Parent=f,
            })
            Corner(kb, 7)
            Stroke(kb, T.BorderBright, 1, 0)
            kb.MouseButton1Click:Connect(function()
                listen=true; kb.Text="¬∑¬∑¬∑"; kb.TextColor3=T.Warning
            end)
            kb.MouseEnter:Connect(function()
                Tween(kb, { BackgroundColor3=T.SurfaceAlt }, 0.15)
            end)
            kb.MouseLeave:Connect(function()
                Tween(kb, { BackgroundColor3=T.Background }, 0.15)
            end)
            UserInputService.InputBegan:Connect(function(inp, gp)
                if gp then return end
                if listen and inp.UserInputType==Enum.UserInputType.Keyboard then
                    cur=inp.KeyCode; listen=false
                    kb.Text=inp.KeyCode.Name; kb.TextColor3=T.Primary
                    Safe(cb, inp.KeyCode)
                elseif not listen
                    and inp.UserInputType==Enum.UserInputType.Keyboard
                    and inp.KeyCode==cur then
                    Safe(cb, cur)
                end
            end)
            local El={Value=cur}
            function El:Get() return cur end
            return El
        end

        -- Input
        function Tab:AddInput(icfg)
            icfg = icfg or {}
            local name = icfg.Name or "Input"
            local ph   = icfg.Placeholder or "Type here..."
            local def  = icfg.Default or ""
            local cb   = icfg.Callback or function() end
            local f = EF(60)
            EL(f, name, 12, 8, 260, 18, T.Text, L.FontSemi, 13)
            local box = New("TextBox", {
                Size=UDim2.new(1,-24,0,26),
                Position=UDim2.new(0,12,0,28),
                BackgroundColor3=T.Background,
                Text=def, PlaceholderText=ph,
                PlaceholderColor3=T.TextMuted,
                TextColor3=T.Text, Font=L.FontBody, TextSize=12,
                BorderSizePixel=0, ClearTextOnFocus=false,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=14, Parent=f,
            })
            Corner(box, 6); Pad(box, 0,0,8,8)
            local bs = Stroke(box, T.Border, 1, 0)
            box.Focused:Connect(function()
                Tween(bs, { Color=T.Primary }, 0.15)
            end)
            box.FocusLost:Connect(function(enter)
                Tween(bs, { Color=T.Border }, 0.15)
                if enter then Safe(cb, box.Text) end
            end)
            local El={}
            function El:Get() return box.Text end
            function El:Set(v) box.Text=v end
            return El
        end

        return Tab
    end -- CreateTab

    -- Window API
    local WAPI = {}
    setmetatable(WAPI, {
        __call = function(_, tcfg)
            if type(tcfg)=="string" then tcfg={Name=tcfg} end
            return Window:CreateTab(tcfg)
        end,
        __index = Window,
    })
    function WAPI:CreateTab(c) return Window:CreateTab(c) end
    function WAPI:Toggle()
        if mainFrame.Visible then
            Tween(mainFrame, { Size=UDim2.new(0,size.X.Offset,0,0) }, 0.3,
                Enum.EasingStyle.Quart, Enum.EasingDirection.In)
            task.delay(0.32, function() mainFrame.Visible=false end)
        else
            mainFrame.Visible=true
            Tween(mainFrame, { Size=size }, 0.35, Enum.EasingStyle.Back)
        end
    end
    function WAPI:Destroy()
        Tween(mainFrame, { Size=UDim2.new(0,0,0,0), BackgroundTransparency=1 }, 0.3)
        task.delay(0.35, function() mainFrame:Destroy() end)
    end

    table.insert(self._Windows, WAPI)
    return WAPI
end

-- ============================================================
--  NOTIFICATIONS ‚ÄĒ Simultaneous fade (icon + text together)
-- ============================================================
function CrozoX:Notify(cfg)
    cfg = cfg or {}
    local title    = cfg.Title    or "Notification"
    local text     = cfg.Text     or ""
    local dur      = cfg.Duration or 4
    local ntype    = cfg.Type     or "Info"
    local T        = self._Theme
    local L        = self._Lang

    local xAlign = (L and L.IsRTL)
        and Enum.TextXAlignment.Right
        or  Enum.TextXAlignment.Left

    local typeMap = {
        Success = { color=T.Success, icon=Icons.checkcircle2, bg=T.NotifBgOk  },
        Warning = { color=T.Warning, icon=Icons.alerttriangle, bg=T.NotifBgWarn },
        Error   = { color=T.Error,   icon=Icons.xcircle,       bg=T.NotifBgErr  },
        Info    = { color=T.Primary, icon=Icons.info,          bg=T.NotifBgInfo },
    }
    local td    = typeMap[ntype] or typeMap.Info
    local color = td.color

    self._NotifCount = self._NotifCount + 1

    -- Card
    local card = New("Frame", {
        Name = "Notif_"..self._NotifCount,
        Size = UDim2.new(1,0,0,78),
        BackgroundColor3 = T.Surface,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 900,
        Parent = self._NotifContainer,
    })
    Corner(card, 12)
    local cs = Stroke(card, color, 1, 0.55)

    -- Coloured left panel
    local panel = New("Frame", {
        Size = UDim2.new(0,44,1,0),
        BackgroundColor3 = td.bg,
        BorderSizePixel=0, ZIndex=901, Parent=card,
    })
    New("UICorner", { CornerRadius=UDim.new(0,12), Parent=panel })
    New("Frame", {
        Size=UDim2.new(0,8,1,0),
        Position=UDim2.new(1,-8,0,0),
        BackgroundColor3=td.bg,
        BorderSizePixel=0, ZIndex=901, Parent=panel,
    })

    -- Icon ‚ÄĒ anchored to centre of panel
    local iconImg = Img(panel, td.icon, 22,
        UDim2.new(0.5,-11,0.5,-11), color, 903)
    iconImg.ImageTransparency = 1  -- starts invisible

    -- Title
    local titleLbl = New("TextLabel", {
        Size=UDim2.new(1,-96,0,22),
        Position=UDim2.new(0,54,0,13),
        BackgroundTransparency=1,
        Text=title, TextColor3=T.Text,
        Font=Enum.Font.GothamBold, TextSize=13,
        TextXAlignment=xAlign, TextWrapped=false,
        TextTransparency=1,  -- starts invisible
        ZIndex=902, Parent=card,
    })

    -- Body
    local bodyLbl = New("TextLabel", {
        Size=UDim2.new(1,-96,0,28),
        Position=UDim2.new(0,54,0,35),
        BackgroundTransparency=1,
        Text=text, TextColor3=T.TextDim,
        Font=L.FontBody, TextSize=11,
        TextXAlignment=xAlign, TextWrapped=true,
        TextTransparency=1,  -- starts invisible
        ZIndex=902, Parent=card,
    })

    -- Progress bar
    local pbg = New("Frame", {
        Size=UDim2.new(1,-16,0,2),
        Position=UDim2.new(0,8,1,-6),
        BackgroundColor3=T.Border,
        BorderSizePixel=0, ZIndex=902, Parent=card,
    })
    Corner(pbg, 1)
    local pfill = New("Frame", {
        Size=UDim2.new(1,0,1,0),
        BackgroundColor3=color,
        BorderSizePixel=0, ZIndex=903, Parent=pbg,
    })
    Corner(pfill, 1)
    pfill.BackgroundTransparency = 1  -- starts invisible

    -- Close button
    local xBtn = New("TextButton", {
        Size=UDim2.new(0,20,0,20),
        Position=UDim2.new(1,-26,0,8),
        BackgroundTransparency=1, Text="",
        ZIndex=904, Parent=card,
    })
    local xIco = Img(xBtn, Icons.x, 12,
        UDim2.new(0.5,-6,0.5,-6), T.TextMuted, 905)
    xIco.ImageTransparency = 1

    -- ‚ĒÄ‚ĒÄ Slide in + fade everything in SIMULTANEOUSLY ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    card.Position = UDim2.new(1,30,0,0)

    local FADE_IN = 0.38

    -- Card slide + background fade
    Tween(card, {
        BackgroundTransparency = 0,
        Position = UDim2.new(0,0,0,0),
    }, FADE_IN, Enum.EasingStyle.Back)

    -- All content fades in at the same time as card
    Tween(iconImg,   { ImageTransparency=0 }, FADE_IN, Enum.EasingStyle.Quart)
    Tween(titleLbl,  { TextTransparency=0  }, FADE_IN, Enum.EasingStyle.Quart)
    Tween(bodyLbl,   { TextTransparency=0  }, FADE_IN, Enum.EasingStyle.Quart)
    Tween(pfill,     { BackgroundTransparency=0 }, FADE_IN, Enum.EasingStyle.Quart)
    Tween(xIco,      { ImageTransparency=0 }, FADE_IN, Enum.EasingStyle.Quart)

    -- Progress countdown
    Tween(pfill, { Size=UDim2.new(0,0,1,0) }, dur, Enum.EasingStyle.Linear)

    -- ‚ĒÄ‚ĒÄ Dismiss function ‚ÄĒ fade everything out SIMULTANEOUSLY ‚ĒÄ
    local dismissed = false
    local function Dismiss()
        if dismissed then return end
        dismissed = true
        local FADE_OUT = 0.3
        Tween(card,    { BackgroundTransparency=1,
            Position=UDim2.new(1,30,0,0) }, FADE_OUT,
            Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        Tween(iconImg,  { ImageTransparency=1 }, FADE_OUT)
        Tween(titleLbl, { TextTransparency=1  }, FADE_OUT)
        Tween(bodyLbl,  { TextTransparency=1  }, FADE_OUT)
        Tween(pfill,    { BackgroundTransparency=1 }, FADE_OUT)
        Tween(xIco,     { ImageTransparency=1  }, FADE_OUT)
        task.delay(FADE_OUT+0.05, function() card:Destroy() end)
    end

    task.delay(dur, Dismiss)
    xBtn.MouseButton1Click:Connect(Dismiss)

    -- hover
    local hov = New("TextButton", {
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1, Text="",
        ZIndex=901, Parent=card,
    })
    hov.MouseEnter:Connect(function()
        Tween(card, { BackgroundColor3=T.SurfaceAlt }, 0.15)
    end)
    hov.MouseLeave:Connect(function()
        Tween(card, { BackgroundColor3=T.Surface }, 0.15)
    end)
end

