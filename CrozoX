        BackgroundTransparency = 0,
        Position               = UDim2.new(0.5, 0, 0.5, 0),
    }, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    Tween(ringFrame, {
        BackgroundTransparency = 0,
        Position               = UDim2.new(0.5, 0, 0.5, 0),
    }, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- ── Confirm action ────────────────────────────────────────
    confirmBtn.MouseButton1Click:Connect(function()
        Ripple(confirmBtn)
        self:SetLanguage(selectedLang)

        -- Exit animation
        Tween(overlay,    { BackgroundTransparency = 1 }, 0.4)
        Tween(card,       { BackgroundTransparency = 1, Position = UDim2.new(0.5, 0, 0.44, 0) }, 0.35)
        Tween(ringFrame,  { BackgroundTransparency = 1, Position = UDim2.new(0.5, 0, 0.44, 0) }, 0.35)

        task.delay(0.45, function()
            rainbowConn:Disconnect()
            overlay:Destroy()
            card:Destroy()
            ringFrame:Destroy()
            if callback then callback(selectedLang) end
        end)
    end)
end

