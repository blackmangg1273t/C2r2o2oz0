        function Tab:AddSlider(scfg)
            scfg=scfg or {}
            local name=scfg.Name or "Slider"
            local min =scfg.Min  or 0
            local max =scfg.Max  or 100
            local def =math.clamp(scfg.Default or min,min,max)
            local suf =scfg.Suffix or ""
            local cb  =scfg.Callback or function() end
            local val =def
            local f=EF(66)
            EL(f,name,12,10,220,20,T.Text,L.FontSemi,L.LabelSize)
            local vl=New("TextLabel",{Size=UDim2.new(0,88,0,20),
                Position=UDim2.new(1,-100,0,10),BackgroundTransparency=1,
                Text=tostring(val)..suf,TextColor3=T.Primary,
                Font=Enum.Font.GothamBold,TextSize=L.LabelSize,
                TextXAlignment=Enum.TextXAlignment.Right,ZIndex=14,Parent=f})
            local tbg=New("Frame",{Size=UDim2.new(1,-24,0,6),
                Position=UDim2.new(0,12,0,48),BackgroundColor3=T.Border,
                BorderSizePixel=0,ZIndex=14,Parent=f})
            Corner(tbg,3)
            local fill=New("Frame",{Size=UDim2.new((val-min)/(max-min),0,1,0),
                BackgroundColor3=T.Primary,BorderSizePixel=0,ZIndex=15,Parent=tbg})
            Corner(fill,3)
            -- gradient on fill
            local fillGrad=New("UIGradient",{Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,T.PrimaryLight),
                ColorSequenceKeypoint.new(1,T.Primary)},Parent=fill})
            local knob=New("Frame",{Size=UDim2.new(0,16,0,16),
                Position=UDim2.new((val-min)/(max-min),-8,0.5,-8),
                BackgroundColor3=Color3.new(1,1,1),BorderSizePixel=0,
                ZIndex=16,Parent=tbg})
            Corner(knob,8)
            Stroke(knob,T.BorderBright,1,0)
            local drag=false
            local cz=New("TextButton",{Size=UDim2.new(1,0,0,34),
                Position=UDim2.new(0,0,0,34),BackgroundTransparency=1,
                Text="",ZIndex=17,Parent=f})
            cz.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
            end)
            cz.InputEnded:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
            end)
            local El={Value=val}
            local function SV(v,fire)
                v=math.clamp(math.floor(v+0.5),min,max);val=v;El.Value=v
                local p=(v-min)/(max-min)
                Tween(fill,{Size=UDim2.new(p,0,1,0)},0.05)
                Tween(knob,{Position=UDim2.new(p,-8,0.5,-8)},0.05)
                vl.Text=tostring(v)..suf
                if fire~=false then Safe(cb,v) end
            end
            UserInputService.InputChanged:Connect(function(inp)
                if drag and inp.UserInputType==Enum.UserInputType.MouseMovement then
                    local p=math.clamp((inp.Position.X-tbg.AbsolutePosition.X)
                        /tbg.AbsoluteSize.X,0,1)
                    SV(min+p*(max-min))
                end
            end)
            function El:Set(v) SV(v,true) end
            function El:Get() return val end
            return El
        end

        -- ‚ĒÄ‚ĒÄ Dropdown ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddDropdown(dcfg)
            dcfg=dcfg or {}
            local name=dcfg.Name or "Dropdown"
            local opts=dcfg.Options or {}
            local sel =dcfg.Default or opts[1]
            local cb  =dcfg.Callback or function() end
            local open=false
            local f=EF(46); f.ClipsDescendants=false
            EL(f,name,12,13,190,20,T.Text,L.FontSemi,L.LabelSize)
            local sl=New("TextLabel",{Size=UDim2.new(0,110,0,20),
                Position=UDim2.new(1,-145,0,13),BackgroundTransparency=1,
                Text=tostring(sel or "‚ÄĒ"),TextColor3=T.Primary,
                Font=L.FontBody,TextSize=L.LabelSize,
                TextXAlignment=Enum.TextXAlignment.Right,ZIndex=14,Parent=f})
            local aIco=Img(f,Icons.chevrondown,14,
                UDim2.new(1,-25,0.5,-7),T.TextMuted,14)
            local dl=New("Frame",{Size=UDim2.new(1,0,0,0),
                Position=UDim2.new(0,0,1,6),BackgroundColor3=T.Surface,
                BorderSizePixel=0,ClipsDescendants=true,
                ZIndex=60,Visible=false,Parent=f})
            Corner(dl,12)
            Stroke(dl,T.BorderBright,1,0)
            ListLayout(dl,2); Pad(dl,4,4,4,4)
            local El={Value=sel}
            local function SetSel(o)
                sel=o;El.Value=o;sl.Text=tostring(o);Safe(cb,o)
            end
            local function Refresh()
                for _,c in ipairs(dl:GetChildren()) do
                    if c:IsA("Frame") then c:Destroy() end
                end
                for _,o in ipairs(opts) do
                    local isA=(o==sel)
                    local row=New("Frame",{Size=UDim2.new(1,0,0,32),
                        BackgroundColor3=isA and T.SurfaceHover or T.SurfaceAlt,
                        BorderSizePixel=0,ZIndex=61,Parent=dl})
                    Corner(row,8)
                    if isA then
                        New("Frame",{Size=UDim2.new(0,3,0.55,0),
                            Position=UDim2.new(0,0,0.225,0),
                            BackgroundColor3=T.Primary,BorderSizePixel=0,
                            ZIndex=62,Parent=row})
                    end
                    EL(row,tostring(o),10,0,200,32,
                        isA and T.Text or T.TextDim,
                        isA and L.FontSemi or L.FontBody,L.LabelSize,62)
                    local rb=New("TextButton",{Size=UDim2.new(1,0,1,0),
                        BackgroundTransparency=1,Text="",ZIndex=63,Parent=row})
                    rb.MouseEnter:Connect(function()
                        if o~=sel then Tween(row,{BackgroundColor3=T.SurfaceHover},0.1) end
                    end)
                    rb.MouseLeave:Connect(function()
                        if o~=sel then Tween(row,{BackgroundColor3=T.SurfaceAlt},0.1) end
                    end)
                    rb.MouseButton1Click:Connect(function()
                        SetSel(o);open=false
                        Tween(dl,{Size=UDim2.new(1,0,0,0)},0.2)
                        Tween(aIco,{Rotation=0},0.2)
                        task.delay(0.22,function() dl.Visible=false end)
                    end)
                end
            end
            Refresh()
            local tog=New("TextButton",{Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,Text="",ZIndex=15,Parent=f})
            tog.MouseButton1Click:Connect(function()
                open=not open
                if open then
                    Refresh();dl.Visible=true
                    local th=math.min(#opts*34+8,200)
                    Tween(dl,{Size=UDim2.new(1,0,0,th)},0.25,Enum.EasingStyle.Back)
                    Tween(aIco,{Rotation=180},0.2)
                else
                    Tween(dl,{Size=UDim2.new(1,0,0,0)},0.2)
                    Tween(aIco,{Rotation=0},0.2)
                    task.delay(0.22,function() dl.Visible=false end)
                end
            end)
            function El:Set(v) SetSel(v) end
            function El:Get() return sel end
            function El:SetOptions(o) opts=o;Refresh() end
            return El
        end

        -- ‚ĒÄ‚ĒÄ Keybind ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddKeybind(kcfg)
            kcfg=kcfg or {}
            local name=kcfg.Name or "Keybind"
            local def =kcfg.Default or Enum.KeyCode.RightControl
            local cb  =kcfg.Callback or function() end
            local cur=def;local listen=false
            local f=EF(46)
            EL(f,name,12,13,230,20,T.Text,L.FontSemi,L.LabelSize)
            local kb=New("TextButton",{Size=UDim2.new(0,100,0,28),
                Position=UDim2.new(1,-112,0.5,-14),BackgroundColor3=T.Background,
                Text=cur.Name,TextColor3=T.Primary,
                Font=Enum.Font.GothamBold,TextSize=12,
                BorderSizePixel=0,ZIndex=14,Parent=f})
            Corner(kb,8);Stroke(kb,T.BorderBright,1,0)
            kb.MouseButton1Click:Connect(function()
                listen=true;kb.Text="¬∑¬∑¬∑";kb.TextColor3=T.Warning
            end)
            kb.MouseEnter:Connect(function()
                Tween(kb,{BackgroundColor3=T.SurfaceAlt},0.15) end)
            kb.MouseLeave:Connect(function()
                Tween(kb,{BackgroundColor3=T.Background},0.15) end)
            UserInputService.InputBegan:Connect(function(inp,gp)
                if gp then return end
                if listen and inp.UserInputType==Enum.UserInputType.Keyboard then
                    cur=inp.KeyCode;listen=false
                    kb.Text=inp.KeyCode.Name;kb.TextColor3=T.Primary
                    Safe(cb,inp.KeyCode)
                elseif not listen
                    and inp.UserInputType==Enum.UserInputType.Keyboard
                    and inp.KeyCode==cur then Safe(cb,cur) end
            end)
            local El={Value=cur}
            function El:Get() return cur end
            return El
        end

        -- ‚ĒÄ‚ĒÄ Input ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddInput(icfg)
            icfg=icfg or {}
            local name=icfg.Name or "Input"
            local ph  =icfg.Placeholder or "Type here..."
            local def =icfg.Default or ""
            local cb  =icfg.Callback or function() end
            local f=EF(64)
            EL(f,name,12,8,270,20,T.Text,L.FontSemi,L.LabelSize)
            local box=New("TextBox",{Size=UDim2.new(1,-24,0,28),
                Position=UDim2.new(0,12,0,30),BackgroundColor3=T.Background,
                Text=def,PlaceholderText=ph,PlaceholderColor3=T.TextMuted,
                TextColor3=T.Text,Font=L.FontBody,TextSize=L.LabelSize,
                BorderSizePixel=0,ClearTextOnFocus=false,
                TextXAlignment=L.IsRTL and Enum.TextXAlignment.Right or Enum.TextXAlignment.Left,
                ZIndex=14,Parent=f})
            Corner(box,8);Pad(box,0,0,10,10)
            local bs=Stroke(box,T.Border,1,0)
            box.Focused:Connect(function() Tween(bs,{Color=T.Primary},0.15) end)
            box.FocusLost:Connect(function(enter)
                Tween(bs,{Color=T.Border},0.15)
                if enter then Safe(cb,box.Text) end
            end)
            local El={}
            function El:Get() return box.Text end
            function El:Set(v) box.Text=v end
            return El
        end

        return Tab
    end -- CreateTab

    local WAPI={}
    setmetatable(WAPI,{
        __call=function(_,tcfg)
            if type(tcfg)=="string" then tcfg={Name=tcfg} end
            return Window:CreateTab(tcfg)
        end,
        __index=Window,
    })
    function WAPI:CreateTab(c) return Window:CreateTab(c) end
    function WAPI:Toggle()
        if mainFrame.Visible then
            Tween(mainFrame,{Size=UDim2.new(0,size.X.Offset,0,0)},0.3,
                Enum.EasingStyle.Quart,Enum.EasingDirection.In)
            task.delay(0.32,function() mainFrame.Visible=false end)
        else
            mainFrame.Visible=true
            Tween(mainFrame,{Size=size},0.35,Enum.EasingStyle.Back)
        end
    end
    function WAPI:Destroy()
        Tween(mainFrame,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},0.3)
        task.delay(0.35,function() mainFrame:Destroy() end)
    end
    table.insert(self._Windows,WAPI)
    return WAPI
end

