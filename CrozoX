    ringBg.Position=UDim2.new(0.5,0,0.65,0)
    card.Position=UDim2.new(0.5,0,0.65,0)
    Tween(ringBg,{BackgroundTransparency=0,Position=UDim2.new(0.5,0,0.5,0)},
        0.5,Enum.EasingStyle.Back)
    Tween(card,{BackgroundTransparency=0,Position=UDim2.new(0.5,0,0.5,0)},
        0.5,Enum.EasingStyle.Back)

    -- ── Confirm ────────────────────────────────────────────────
    local fired=false
    local function FireConfirm()
        if fired then return end
        fired=true
        rainbowConn:Disconnect()
        local FO = 0.4
        -- كل العناصر تختفي مع بعض في نفس الوقت
        Tween(overlay, {BackgroundTransparency=1}, FO)
        Tween(ringBg,  {BackgroundTransparency=1, Position=UDim2.new(0.5,0,0.44,0)}, FO, Enum.EasingStyle.Quart)
        Tween(card,    {BackgroundTransparency=1, Position=UDim2.new(0.5,0,0.44,0)}, FO, Enum.EasingStyle.Quart)
        -- كل children في الـ card تختفي
        for _, child in ipairs(card:GetDescendants()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("ImageLabel") then
                Tween(child, {
                    TextTransparency  = child:IsA("TextLabel")  and 1 or nil,
                    BackgroundTransparency = 1,
                    ImageTransparency = child:IsA("ImageLabel") and 1 or nil,
                }, FO)
            end
        end
        task.delay(FO+0.05, function()
            overlay:Destroy(); lsWrapper:Destroy()
            if onDone then task.spawn(function() onDone(selectedLang) end) end
        end)
    end

    confirmBtn.MouseButton1Click:Connect(function()
        Ripple(confirmBtn)
        FireConfirm()
    end)
end

