            end
        end)

        btnData[langName] = {
            frame=frame, stroke=fStroke, label=lbl, dot=dot,
            color=tc, clickBtn=clickBtn,
        }
        return clickBtn
    end

    MakeLangBtn("English", "ūüáļūüáł", "English",  true)
    MakeLangBtn("Arabic",  "ūüáłūüá¶", "ōßŔĄōĻōĪō®Ŕäō©",  false)

    local function SelectLang(name)
        if selectedLang == name then return end
        local prev = btnData[selectedLang]
        local next = btnData[name]
        if prev then
            Tween(prev.frame, { BackgroundColor3=Color3.fromRGB(18,18,24) }, 0.2)
