    local function DoClose()
        -- Collect all visible elements and fade them simultaneously
        local FO = 0.28
        -- Main frame scales down and fades ‚ÄĒ single tween as one block
        Tween(mainFrame, {
            Size                   = UDim2.new(0.92, 0, 0.92, 0),
            BackgroundTransparency = 1,
        }, FO, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        Tween(shadowImg, {ImageTransparency = 1}, FO * 0.8)
        Tween(glowStroke, {Transparency = 1}, FO * 0.6)
        -- Fade ALL text/image elements at same time
        for _, desc in ipairs(mainFrame:GetDescendants()) do
            if desc:IsA("TextLabel") then
                Tween(desc, {TextTransparency=1}, FO * 0.7)
            elseif desc:IsA("ImageLabel") then
                Tween(desc, {ImageTransparency=1}, FO * 0.7)
            end
        end
        task.delay(FO + 0.05, function()
            if wrapFrame and wrapFrame.Parent then wrapFrame:Destroy() end
        end)
    end

    local function DoMinimize()
        isMin = not isMin
        if isMin then
            -- FIX 5E: smooth minimize ‚ÄĒ content fades first, then height collapses
            local FO = 0.18
            for _, desc in ipairs(contentArea:GetDescendants()) do
                if desc:IsA("TextLabel") then
                    Tween(desc, {TextTransparency=1}, FO)
                elseif desc:IsA("ImageLabel") then
                    Tween(desc, {ImageTransparency=1}, FO)
                end
            end
            for _, desc in ipairs(sidebar:GetDescendants()) do
                if desc:IsA("TextLabel") then
                    Tween(desc, {TextTransparency=1}, FO)
                elseif desc:IsA("ImageLabel") then
                    Tween(desc, {ImageTransparency=1}, FO)
                end
            end
            task.delay(FO, function()
                if not mainFrame.Parent then return end
                Tween(mainFrame, {Size = UDim2.new(1, 0, 0, 54)}, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
                Tween(shadowImg, {ImageTransparency = 1}, 0.2)
                resizeBtn.Visible = false
            end)
        else
            -- Restore: expand first, then fade elements back in
            resizeBtn.Visible = true
            Tween(mainFrame, {Size = UDim2.new(1, 0, 1, 0)}, 0.35, Enum.EasingStyle.Back)
            Tween(shadowImg, {ImageTransparency = 0.55}, 0.35)
