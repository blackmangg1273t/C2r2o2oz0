    -- ══════════════════════════════════════════════════════
    --  DRAG + RESIZE + SHADOW — كل شيء في RenderStepped
    -- ══════════════════════════════════════════════════════
    local dragging   = false
    local resizing   = false
    local lastMouseX = 0
    local lastMouseY = 0
    local rStartX    = 0
    local rStartY    = 0
    local rW         = 0
    local rH         = 0
    local rPX        = 0
    local rPY        = 0
    local MIN_W, MIN_H = 420, 300
    local MAX_W, MAX_H = 1200, 800

    -- ── Drag Button — TextButton شفاف فوق titleBar ─────────
    local dragBtn = New("TextButton", {
        Size                   = UDim2.new(1, -90, 1, 0),
        Position               = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        Text                   = "",
        ZIndex                 = 20,
        Parent                 = titleBar,
    })

    -- ══════════════════════════════════════════════════════
    --  DRAG SYSTEM — منفصل تماماً: Mouse (delta) | Touch (absolute)
    --  المشكلة في v41: كان lastMouseX/Y بيتحدث من InputChanged
    --  وبيتحسب منه delta في RenderStepped → conflict
    --  الحل: Touch يستخدم absolute positioning مش delta
    -- ══════════════════════════════════════════════════════
    local touchDragging = false
    local touchStartX   = 0
    local touchStartY   = 0
    local wrapStartPX   = 0
    local wrapStartPY   = 0

    dragBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            if resizing then return end
            local mp = UserInputService:GetMouseLocation()
            lastMouseX = mp.X
            lastMouseY = mp.Y
            dragging   = true
        elseif inp.UserInputType == Enum.UserInputType.Touch then
            if resizing or holdActive then return end
            touchDragging = true
            dragging      = false
            touchStartX   = inp.Position.X
            touchStartY   = inp.Position.Y
            wrapStartPX   = wrapFrame.Position.X.Offset
            wrapStartPY   = wrapFrame.Position.Y.Offset
        end
    end)

    -- نستخدم UserInputService عشان يستمر حتى بعد ما الإصبع يبعد عن dragBtn
    UserInputService.InputChanged:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch and touchDragging then
            local dx = inp.Position.X - touchStartX
            local dy = inp.Position.Y - touchStartY
            wrapFrame.Position = UDim2.new(0, wrapStartPX + dx, 0, wrapStartPY + dy)
            smoothX = wrapStartPX + dx
            smoothY = wrapStartPY + dy
            dispX   = smoothX
            dispY   = smoothY
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
