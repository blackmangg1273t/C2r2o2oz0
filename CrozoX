    local cardTitle=New("TextLabel",{Size=UDim2.new(1,0,0,32),Position=UDim2.new(0,0,0,78),
        BackgroundTransparency=1,Text="CrozoX",
        TextColor3=Color3.fromRGB(235,238,255),Font=Enum.Font.GothamBlack,
        TextSize=24,ZIndex=205,Parent=card})

    local cardSub=New("TextLabel",{Size=UDim2.new(1,-32,0,20),Position=UDim2.new(0,16,0,112),
        BackgroundTransparency=1,
        Text="Select Language  /  ōßōģō™ōĪ ōßŔĄŔĄōļō©",
        TextColor3=Color3.fromRGB(125,130,158),Font=Enum.Font.Gotham,
        TextSize=13,ZIndex=205,Parent=card})

    local divider=New("Frame",{Size=UDim2.new(0.72,0,0,1),AnchorPoint=Vector2.new(0.5,0),
        Position=UDim2.new(0.5,0,0,138),BackgroundColor3=Color3.fromRGB(42,46,68),
        BorderSizePixel=0,ZIndex=205,Parent=card})

    local row=New("Frame",{Size=UDim2.new(1,-48,0,94),
        Position=UDim2.new(0,24,0,152),BackgroundTransparency=1,
        ZIndex=205,Parent=card})
    ListLayout(row,14,Enum.FillDirection.Horizontal,
        Enum.HorizontalAlignment.Center,Enum.VerticalAlignment.Center)

    local selectedLang="English"
    local btnData={}
    local THEME_COLORS={English=Color3.fromRGB(56,132,255),Arabic=Color3.fromRGB(220,38,38)}

    local function MakeLangBtn(langName,flagEmoji,labelText,isDefault)
        local tc=THEME_COLORS[langName]
        local frame=New("Frame",{Size=UDim2.new(0,165,0,88),
            BackgroundColor3=isDefault and Color3.fromRGB(20,26,46) or Color3.fromRGB(18,18,24),
            BorderSizePixel=0,ZIndex=206,Parent=row})
        Corner(frame,14)
        local fStroke=Stroke(frame,isDefault and tc or Color3.fromRGB(42,46,68),
            isDefault and 2 or 1,0)
        local flagLbl=New("TextLabel",{Size=UDim2.new(1,0,0,40),Position=UDim2.new(0,0,0,8),
            BackgroundTransparency=1,Text=flagEmoji,TextSize=30,ZIndex=207,Parent=frame})
        local lbl=New("TextLabel",{Size=UDim2.new(1,-8,0,26),
            Position=UDim2.new(0,4,0,54),BackgroundTransparency=1,
            Text=labelText,
            TextColor3=isDefault and tc or Color3.fromRGB(148,152,172),
            Font=Enum.Font.GothamBold,TextSize=14,ZIndex=207,Parent=frame})
        local dot=New("Frame",{Size=UDim2.new(0,7,0,7),
            AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-6,0,6),
            BackgroundColor3=tc,
            BackgroundTransparency=isDefault and 0 or 1,
            BorderSizePixel=0,ZIndex=208,Parent=frame})
        Corner(dot,4)
        local clickBtn=New("TextButton",{Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1,Text="",ZIndex=209,Parent=frame})

        -- Hover
        clickBtn.MouseEnter:Connect(function()
            if selectedLang~=langName then
                Tween(frame,{BackgroundColor3=Color3.fromRGB(24,28,40)},0.15) end
        end)
        clickBtn.MouseLeave:Connect(function()
            if selectedLang~=langName then
                Tween(frame,{BackgroundColor3=Color3.fromRGB(18,18,24)},0.15) end
        end)
        btnData[langName]={frame=frame,stroke=fStroke,label=lbl,dot=dot,
            flag=flagLbl,color=tc,clickBtn=clickBtn}
        return clickBtn
    end
    MakeLangBtn("English","ūüáļūüáł","English",true)
    MakeLangBtn("Arabic","ūüáłūüá¶","ōßŔĄōĻōĪō®Ŕäō©",false)

    local confirmBtn

    -- FIX 2A: Selection animation ‚ÄĒ scale bounce + glow effect
    local function SelectLang(name)
        if selectedLang==name then return end
        local prev=btnData[selectedLang]; local next=btnData[name]
        -- Deselect previous with scale-down
        if prev then
            Tween(prev.frame,{BackgroundColor3=Color3.fromRGB(18,18,24)},0.22)
            Tween(prev.frame,{Size=UDim2.new(0,165,0,88)},0.15)
            prev.stroke.Color=Color3.fromRGB(42,46,68); prev.stroke.Thickness=1
            prev.label.TextColor3=Color3.fromRGB(148,152,172)
            prev.dot.BackgroundTransparency=1
        end
        -- Select new with scale-up bounce
        if next then
            -- Quick scale pop: shrink then expand
            Tween(next.frame,{Size=UDim2.new(0,160,0,84)},0.08,Enum.EasingStyle.Quad)
            task.delay(0.08,function()
                if not next.frame.Parent then return end
                Tween(next.frame,{
                    Size=UDim2.new(0,170,0,92),
                    BackgroundColor3=Color3.fromRGB(20,26,46)
                },0.2,Enum.EasingStyle.Back)
                task.delay(0.2,function()
                    if not next.frame.Parent then return end
                    Tween(next.frame,{Size=UDim2.new(0,165,0,88)},0.12,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                end)
            end)
            next.stroke.Color=next.color; next.stroke.Thickness=2
            next.label.TextColor3=next.color
            Tween(next.dot,{BackgroundTransparency=0},0.2)
        end
        selectedLang=name
        if confirmBtn then
            Tween(confirmBtn,{BackgroundColor3=THEME_COLORS[name]},0.25)
        end
    end

    for ln,d in pairs(btnData) do
        d.clickBtn.MouseButton1Click:Connect(function() SelectLang(ln) end)
    end

    confirmBtn=New("TextButton",{Size=UDim2.new(1,-48,0,44),
        Position=UDim2.new(0,24,1,-58),
        BackgroundColor3=THEME_COLORS.English,
        Text="Continue  ‚Üí",
        TextColor3=Color3.fromRGB(255,255,255),
        Font=Enum.Font.GothamBold,TextSize=15,
        BorderSizePixel=0,ZIndex=206,Parent=card})
    Corner(confirmBtn,12)

    confirmBtn.MouseEnter:Connect(function()
        Tween(confirmBtn,{BackgroundColor3=THEME_COLORS[selectedLang]:Lerp(
            Color3.fromRGB(0,0,0),0.25)},0.15)
    end)
    confirmBtn.MouseLeave:Connect(function()
        Tween(confirmBtn,{BackgroundColor3=THEME_COLORS[selectedLang]},0.15)
    end)

    -- Entrance
    ringBg.Position=UDim2.new(0.5,0,0.72,0)
    card.Position=UDim2.new(0.5,0,0.72,0)
    Tween(ringBg,{BackgroundTransparency=0,Position=UDim2.new(0.5,0,0.5,0)},
        0.5,Enum.EasingStyle.Back)
    Tween(card,{BackgroundTransparency=0,Position=UDim2.new(0.5,0,0.5,0)},
        0.5,Enum.EasingStyle.Back)

    -- FIX 2B: All elements disappear simultaneously as one block
    local fired=false
    local function FireConfirm()
        if fired then return end
        fired=true
        rainbowConn:Disconnect()
        local FO = 0.32

        -- Collect all transparent-able objects in card
        local function FadeOut(inst, delay_)
            delay_ = delay_ or 0
            task.delay(delay_, function()
                if not inst or not inst.Parent then return end
                if inst:IsA("Frame") then
                    Tween(inst,{BackgroundTransparency=1},FO,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                elseif inst:IsA("TextLabel") then
                    Tween(inst,{TextTransparency=1,BackgroundTransparency=1},FO)
                elseif inst:IsA("TextButton") then
                    Tween(inst,{TextTransparency=1,BackgroundTransparency=1},FO)
                elseif inst:IsA("ImageLabel") then
                    Tween(inst,{ImageTransparency=1,BackgroundTransparency=1},FO)
                elseif inst:IsA("UIStroke") then
                    Tween(inst,{Transparency=1},FO)
                end
                -- Recurse into children
                for _,child in ipairs(inst:GetChildren()) do
                    FadeOut(child, 0)
                end
            end)
        end

        -- Fade overlay + ringBg + card ALL at exact same time
        Tween(overlay,{BackgroundTransparency=1},FO,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        Tween(ringBg,{BackgroundTransparency=1,Position=UDim2.new(0.5,0,0.42,0)},FO,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        Tween(card,{BackgroundTransparency=1,Position=UDim2.new(0.5,0,0.42,0)},FO,Enum.EasingStyle.Quart,Enum.EasingDirection.In)

        -- All card children at once ‚ÄĒ no delay between them
        for _,child in ipairs(card:GetDescendants()) do
            FadeOut(child, 0)
        end

        task.delay(FO+0.08, function()
            overlay:Destroy(); lsWrapper:Destroy()
            if onDone then task.spawn(function() onDone(selectedLang) end) end
        end)
    end

    confirmBtn.MouseButton1Click:Connect(function()
        Ripple(confirmBtn)
        FireConfirm()
    end)
    -- Mobile touch
    confirmBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Touch then
            Ripple(confirmBtn)
            FireConfirm()
        end
    end)
end

