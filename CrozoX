        local function SelectTab()
            if activeTab then
                activeTab.Page.Visible = false
                Tween(activeTab.Btn,  { BackgroundColor3=T.SurfaceAlt  }, 0.2)
                Tween(activeTab.Lbl,  { TextColor3=T.TextMuted          }, 0.2)
                Tween(activeTab.Icon, { ImageColor3=T.TextMuted         }, 0.2)
                Tween(activeTab.Ind,  { BackgroundTransparency=1        }, 0.2)
            end
            tabPage.Visible = true
            Tween(tabBtn,    { BackgroundColor3=T.SurfaceHover }, 0.2)
            Tween(tabLabel,  { TextColor3=T.Text               }, 0.2)
            Tween(tabIcon,   { ImageColor3=T.Primary           }, 0.2)
            Tween(indicator, { BackgroundTransparency=0        }, 0.2)
            activeTab = { Btn=tabBtn, Page=tabPage,
                          Lbl=tabLabel, Icon=tabIcon, Ind=indicator }
        end

        tabClick.MouseButton1Click:Connect(function()
            Ripple(tabClick); SelectTab()
