                            BackgroundColor3=T.Primary,
                            BorderSizePixel=0, ZIndex=62, Parent=row,
                        })
                    end
                    EL(row, tostring(o), 8, 0, 200, 28,
                        isA and T.Text or T.TextDim,
                        isA and L.FontSemi or L.FontBody, 12, 62)
