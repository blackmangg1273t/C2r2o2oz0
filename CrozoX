            shimmerConn:Disconnect()
            shimmerConn = nil
        end

        -- الـ fade-in الصح: من 1 لـ 0 (مش instant set + tween من 0 لـ 0)
        Tween(avatarImg, {ImageTransparency = 0}, 0.4, Enum.EasingStyle.Quad)

        -- نشيل الـ loading بعد شوية عشان الـ animation يبدأ الأول
        task.wait(0.1)
        Tween(loadingFrame, {BackgroundTransparency = 1}, 0.35)
        task.delay(0.45, function()
            if loadingFrame and loadingFrame.Parent then
                loadingFrame:Destroy()
            end
        end)
    end)
    New("TextLabel", {
