-- ============================================================
--  UTILITY
-- ============================================================
local function Tween(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    local tw = TweenService:Create(obj, TweenInfo.new(t or 0.25, style, dir), props)
    tw:Play()
    return tw
end
local function TweenWait(obj, props, t, style, dir)
    local tw = Tween(obj,props,t,style,dir); tw.Completed:Wait(); return tw
end
local function New(class, props)
    local o = Instance.new(class)
    for k,v in pairs(props or {}) do if k~="Parent" then o[k]=v end end
    if props and props.Parent then o.Parent=props.Parent end
    return o
end
-- ← حواف منحنية — الرقم الكبير = أكثر استدارة
local function Corner(p, r)
    return New("UICorner",{CornerRadius=UDim.new(0,r or 10),Parent=p})
end
local function Stroke(p, color, thick, trans)
    return New("UIStroke",{Color=color or Color3.new(1,1,1),
        Thickness=thick or 1,Transparency=trans or 0,Parent=p})
end
local function Pad(p,t,b,l,r)
    return New("UIPadding",{PaddingTop=UDim.new(0,t or 8),
        PaddingBottom=UDim.new(0,b or 8),PaddingLeft=UDim.new(0,l or 8),
        PaddingRight=UDim.new(0,r or 8),Parent=p})
end
local function ListLayout(p,spacing,dir,ha,va)
    return New("UIListLayout",{Padding=UDim.new(0,spacing or 6),
        FillDirection=dir or Enum.FillDirection.Vertical,
        HorizontalAlignment=ha or Enum.HorizontalAlignment.Left,
        VerticalAlignment=va or Enum.VerticalAlignment.Top,
        SortOrder=Enum.SortOrder.LayoutOrder,Parent=p})
end
local function Img(parent,asset,sz,pos,color,zi)
    return New("ImageLabel",{Size=UDim2.new(0,sz or 16,0,sz or 16),
        Position=pos or UDim2.new(0,0,0,0),BackgroundTransparency=1,
        Image=asset or "",ImageColor3=color or Color3.new(1,1,1),
        ScaleType=Enum.ScaleType.Fit,ZIndex=zi or 14,Parent=parent})
end
local function Ripple(target)
    -- target ممكن يكون Frame أو TextButton
    local absPos  = target.AbsolutePosition
    local absSize = target.AbsoluteSize
    local r=New("Frame",{Size=UDim2.new(0,0,0,0),AnchorPoint=Vector2.new(0.5,0.5),
        BackgroundColor3=Color3.new(1,1,1),BackgroundTransparency=0.72,
        BorderSizePixel=0,ZIndex=target.ZIndex+10,Parent=target})
    Corner(r,100)
    r.Position=UDim2.new(0,Mouse.X-absPos.X, 0,Mouse.Y-absPos.Y)
    local sz=math.max(absSize.X,absSize.Y)*2.8
    Tween(r,{Size=UDim2.new(0,sz,0,sz),BackgroundTransparency=1},0.5)
    Debris:AddItem(r,0.55)
end
local function Safe(fn,...)
    local ok,e=pcall(fn,...); if not ok then warn("[CrozoX] "..tostring(e)) end; return ok
end
local _cache={}
local function SaveCfg(name,data)
    _cache[name]=data
    if writefile then Safe(function()
        writefile("CrozoX_"..name..".json",
            game:GetService("HttpService"):JSONEncode(data))
    end) end
end
local function LoadCfg(name)
    if _cache[name] then return _cache[name] end
    if readfile and isfile then
        local path="CrozoX_"..name..".json"
        if pcall(isfile,path) then
            local ok,raw=pcall(readfile,path)
            if ok and raw then
                local ok2,d=pcall(function()
                    return game:GetService("HttpService"):JSONDecode(raw)
                end)
                if ok2 then return d end
            end
        end
    end
    return {}
end

