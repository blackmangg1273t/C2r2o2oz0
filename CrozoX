    -- ‚ĒÄ‚ĒÄ FIX: Mobile hold-to-resize ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    -- Problem: InputBegan immediately started resize ‚Üí UI shrank on first touch
    -- Fix: Use a holdTimer. NO visual change, NO resize until timer fires.
    -- Only AFTER 0.35s hold, we snapshot size and activate resize mode.
    local holdTimer    = nil
    local holdActive   = false
    local touchResizeStartX = 0
    local touchResizeStartY = 0

    if not Device.IsPC then
        resizeBtn.InputBegan:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.Touch then return end
            -- FIX: Do NOT change size or activate anything yet
            holdActive = false
            if holdTimer then task.cancel(holdTimer); holdTimer = nil end

            -- Capture touch start position for when hold confirms
            touchResizeStartX = inp.Position.X
            touchResizeStartY = inp.Position.Y

            holdTimer = task.delay(0.35, function()
                holdTimer  = nil
                holdActive = true
                -- NOW snapshot current UI size
                rStartX = touchResizeStartX
                rStartY = touchResizeStartY
                rW  = wrapFrame.AbsoluteSize.X
                rH  = wrapFrame.AbsoluteSize.Y
                rPX = wrapFrame.Position.X.Offset
                rPY = wrapFrame.Position.Y.Offset
                resizing   = true
                dragging   = false
                touchDragging = false
                -- Visual feedback only AFTER hold confirmed
                Tween(resizeBtn,{BackgroundColor3=T.Primary,BackgroundTransparency=0},0.12)
            end)
        end)

        resizeBtn.InputEnded:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.Touch then return end
            -- Cancel hold if finger lifted before threshold
            if holdTimer then task.cancel(holdTimer); holdTimer = nil end
            if holdActive then
                holdActive = false
                resizing   = false
                Tween(resizeBtn,{BackgroundColor3=Color3.fromRGB(30,30,30),BackgroundTransparency=0.1},0.2)
            end
        end)
    end

    -- ‚ĒÄ‚ĒÄ Shared resize move (PC + mobile after hold) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    -- FIX: Use UserInputService for resize movement (needs global tracking)
    -- But ONLY when resizing == true, which on mobile only happens after hold
    UserInputService.InputChanged:Connect(function(inp)
        if not resizing then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            local mp2 = UserInputService:GetMouseLocation()
            local newW = math.clamp(rW + (mp2.X - rStartX), MIN_W, MAX_W)
            local newH = math.clamp(rH + (mp2.Y - rStartY), MIN_H, MAX_H)
            wrapFrame.Size     = UDim2.new(0,newW,0,newH)
            wrapFrame.Position = UDim2.new(0,rPX,0,rPY)
            smoothX=rPX; smoothY=rPY; dispX=rPX; dispY=rPY
            size = UDim2.new(0,newW,0,newH)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and resizing and Device.IsPC then
            resizing = false
            Tween(resizeBtn,{BackgroundColor3=Color3.fromRGB(30,30,30),BackgroundTransparency=0.1},0.15)
        end
    end)

    -- ‚ĒÄ‚ĒÄ RenderStepped: PC drag smooth lerp only ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local smoothX = 0
    local smoothY = 0
    local dispX   = 0
    local dispY   = 0
    local smoothInit = false

    RunService.RenderStepped:Connect(function()
        if not wrapFrame.Parent then return end

        local mp = UserInputService:GetMouseLocation()

        -- PC drag with delta + lerp
        if dragging and Device.IsPC then
            local dx = mp.X - lastMouseX
            local dy = mp.Y - lastMouseY
            smoothX = smoothX + dx
            smoothY = smoothY + dy
            lastMouseX = mp.X
            lastMouseY = mp.Y
        end

        if not smoothInit then
            smoothInit = true
            smoothX = wrapFrame.Position.X.Offset
            smoothY = wrapFrame.Position.Y.Offset
            dispX   = smoothX
            dispY   = smoothY
        end

        -- Apply lerp for PC drag
        if dragging and Device.IsPC then
            dispX = dispX + (smoothX - dispX) * 0.28
            dispY = dispY + (smoothY - dispY) * 0.28
            wrapFrame.Position = UDim2.new(0, dispX, 0, dispY)
        end

        -- PC resize
        if resizing and Device.IsPC then
            local newW = math.clamp(rW + (mp.X - rStartX), MIN_W, MAX_W)
            local newH = math.clamp(rH + (mp.Y - rStartY), MIN_H, MAX_H)
            wrapFrame.Size     = UDim2.new(0,newW,0,newH)
            wrapFrame.Position = UDim2.new(0,rPX,0,rPY)
            smoothX = rPX; smoothY = rPY; dispX = rPX; dispY = rPY
            size    = UDim2.new(0,newW,0,newH)
        end
    end)

    -- Open animation
    mainFrame.BackgroundTransparency = 1

    task.defer(function()
        if not sg.Parent then return end
        local sw = sg.AbsoluteSize.X
        local sh = sg.AbsoluteSize.Y
        local baseW = size.X.Offset
        local baseH = size.Y.Offset
        local visualW, visualH, scaleVal = Device.CalcLayout(baseW, baseH)

        wrapFrame.Size = UDim2.new(0, baseW, 0, baseH)
        wrapFrame.Position = UDim2.new(
            0, math.floor((sw - visualW) / 2),
            0, math.floor((sh - visualH) / 2)
        )

        local existing = wrapFrame:FindFirstChildWhichIsA("UIScale")
        if existing then existing:Destroy() end
        if scaleVal ~= 1 then
            New("UIScale", {Scale=scaleVal, Parent=wrapFrame})
        end

        -- Re-sync smooth vars after layout
        smoothX = wrapFrame.Position.X.Offset
        smoothY = wrapFrame.Position.Y.Offset
        dispX   = smoothX; dispY = smoothY

        mainFrame.Size = UDim2.new(0.88,0,0.88,0)
        Tween(mainFrame, {
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=0,
        }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)

    -- Close / Minimize
    local isMin = false

    local function DoClose()
        Tween(mainFrame,{Size=UDim2.new(0.9,0,0.9,0),BackgroundTransparency=1},
            0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        Tween(shadowImg, {ImageTransparency=1}, 0.25)
        task.delay(0.32, function() wrapFrame:Destroy() end)
    end

    local function DoMinimize()
        isMin = not isMin
        if isMin then
            Tween(mainFrame,{Size=UDim2.new(1,0,0,54)},0.3)
            Tween(shadowImg,{ImageTransparency=1},0.2)
            if Device.IsPC then
                Tween(resizeBtn,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},0.2,Enum.EasingStyle.Quart)
                task.delay(0.2,function() if resizeBtn and resizeBtn.Parent then resizeBtn.Visible=false end end)
            else
                Tween(resizeBtn,{BackgroundTransparency=0.7},0.2)
            end
        else
            Tween(mainFrame,{Size=UDim2.new(1,0,1,0)},0.35,Enum.EasingStyle.Back)
            Tween(shadowImg,{ImageTransparency=0.55},0.35)
            if Device.IsPC then
                resizeBtn.Visible=true
                resizeBtn.Size=UDim2.new(0,0,0,0)
                Tween(resizeBtn,{Size=UDim2.new(0,22,0,22),BackgroundTransparency=0.1},0.3,Enum.EasingStyle.Back)
            else
                Tween(resizeBtn,{BackgroundTransparency=0.3},0.2)
            end
        end
    end

    local function ConnectBtn(btn, fn)
        if Device.IsPC then
            btn.MouseButton1Click:Connect(fn)
        else
            local pressing = false
            btn.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.Touch then pressing=true end
            end)
            btn.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.Touch and pressing then
                    pressing=false; fn()
                end
            end)
        end
