-- ============================================================
--  ENTRY POINT
-- ============================================================
local function Init()
    local lib = setmetatable({}, CrozoX)
    lib._Theme      = Themes.Blue
    lib._Lang       = Languages.English
    lib._LangName   = "English"
    lib._Windows    = {}
    lib._NotifCount = 0
    lib._ConfigData = {}

    lib:_Init()
    local sg = lib._ScreenGui

    -- Public API
    local API = {}
    API.Lang  = Languages
    API.Icons = Icons

    function API:CreateWindow(cfg)
        if type(cfg)=="string" then cfg={Title=cfg} end
        return lib:CreateWindow(cfg)
    end
    function API:SetTheme(n)   lib:SetTheme(n)       end
    function API:SetLanguage(n) lib:SetLanguage(n)   end
    function API:Notify(cfg)   lib:Notify(cfg)        end
    function API:SaveConfig(n) lib:SaveConfig(n)      end
    function API:LoadConfig(n) return lib:LoadConfig(n) end
    function API:GetTheme()    return lib._Theme      end
    function API:GetLang()     return lib._Lang       end
    function API:GetLangName() return lib._LangName   end

    setmetatable(API, {
        __call = function(_, cfg)
            if type(cfg)=="string" then
                if Themes[cfg] then lib:SetTheme(cfg); return API end
                return lib:CreateWindow({Title=cfg})
            elseif type(cfg)=="table" then
                return lib:CreateWindow(cfg)
            end
        end,
    })

    -- ‚ĒÄ‚ĒÄ SEQUENCE: Intro ‚Üí LangSelect ‚Üí (window appears after) ‚ĒÄ‚ĒÄ
    PlayIntro(sg, function()
        ShowLangSelect(sg, function(langName)
            lib:SetLanguage(langName)
            -- Welcome notification (after language chosen)
            lib:Notify({
                Title    = langName=="Arabic" and "ŔÖōĪō≠ō®ōßŔč ō®ŔÉ ŔĀŔä CrozoX" or "Welcome to CrozoX",
                Text     = langName=="Arabic"
                    and "ō™ŔÖ ō™ō≠ŔÖŔäŔĄ ōßŔĄŔÖŔÉō™ō®ō© ō®ŔÜō¨ōßō≠ ‚úď"
                    or  "Library loaded successfully ‚úď",
                Duration = 5,
                Type     = "Success",
            })
            -- Resolve any pending CreateWindow calls
            if lib._pendingWindow then
                task.spawn(lib._pendingWindow)
                lib._pendingWindow = nil
            end
        end)
    end)

    return API
end

return Init()
