        BackgroundColor3     = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 1,
        ZIndex               = 500,
        Parent               = sg,
    })
    Tween(overlay, { BackgroundTransparency = 0.45 }, 0.4)

    -- ── Outer rainbow ring (animated via RunService) ──────────
    local CARD_W, CARD_H = 420, 320
    local ringSize = 6   -- border thickness

    -- Ring frame (slightly larger than card)
    local ringFrame = Create("Frame", {
        Name                 = "RainbowRing",
        Size                 = UDim2.new(0, CARD_W + ringSize*2, 0, CARD_H + ringSize*2),
        AnchorPoint          = Vector2.new(0.5, 0.5),
        Position             = UDim2.new(0.5, 0, 0.6, 0),
        BackgroundColor3     = Color3.fromRGB(255, 0, 0),
        BorderSizePixel      = 0,
        BackgroundTransparency = 1,
        ZIndex               = 501,
        Parent               = sg,
    })
    RoundCorner(ringFrame, 20)

    -- We simulate the rainbow border with 4 thin frames on edges
    local function MakeEdge(size, pos, zidx)
        local e = Create("Frame", {
            Size            = size,
            Position        = pos,
            BackgroundColor3 = Color3.fromRGB(255, 80, 80),
            BorderSizePixel = 0,
            ZIndex          = zidx or 502,
            Parent          = ringFrame,
        })
        RoundCorner(e, 3)
        return e
    end
    local edgeTop    = MakeEdge(UDim2.new(1, 0, 0, ringSize), UDim2.new(0,0,0,0))
    local edgeBot    = MakeEdge(UDim2.new(1, 0, 0, ringSize), UDim2.new(0,0,1,-ringSize))
    local edgeLeft   = MakeEdge(UDim2.new(0, ringSize, 1, 0), UDim2.new(0,0,0,0))
    local edgeRight  = MakeEdge(UDim2.new(0, ringSize, 1, 0), UDim2.new(1,-ringSize,0,0))

    -- Animate rainbow colours on edges
    local hue = 0
    local rainbowConn
    rainbowConn = RunService.RenderStepped:Connect(function(dt)
        if not ringFrame.Parent then rainbowConn:Disconnect() return end
        hue = (hue + dt * 0.35) % 1
        local c1 = Color3.fromHSV(hue,             0.9, 1)
        local c2 = Color3.fromHSV((hue + 0.25) % 1, 0.9, 1)
        local c3 = Color3.fromHSV((hue + 0.50) % 1, 0.9, 1)
        local c4 = Color3.fromHSV((hue + 0.75) % 1, 0.9, 1)
        edgeTop.BackgroundColor3   = c1
        edgeRight.BackgroundColor3 = c2
        edgeBot.BackgroundColor3   = c3
        edgeLeft.BackgroundColor3  = c4
