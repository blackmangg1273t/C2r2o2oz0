function CrozoX:_Init()
    local existing=CoreGui:FindFirstChild("CrozoX")
    if existing then existing:Destroy() end
    local sg=New("ScreenGui",{Name="CrozoX",ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
        DisplayOrder=999,IgnoreGuiInset=true})
    local ok=Safe(function() sg.Parent=CoreGui end)
    if not ok then sg.Parent=LocalPlayer:WaitForChild("PlayerGui") end
    self._ScreenGui=sg
    do
        local _nc  = workspace.CurrentCamera
        local _nv  = _nc and _nc.ViewportSize or Vector2.new(800,600)
        local isMobInit = (Device.IsMobile or Device.IsTablet) or (math.min(_nv.X,_nv.Y) < 500)
        local notifW    = isMobInit and 260 or 345
        local notifOff  = notifW + 12
        local notifGap  = isMobInit and 6 or 10
        self._NotifContainer=New("Frame",{Name="NotifContainer",
            Size=UDim2.new(0,notifW,1,0),
            Position=UDim2.new(1,-notifOff,0,0),
            BackgroundTransparency=1,ZIndex=900,Parent=sg})
        ListLayout(self._NotifContainer,notifGap,Enum.FillDirection.Vertical,
            Enum.HorizontalAlignment.Right,Enum.VerticalAlignment.Bottom)
    end
    return sg
end
function CrozoX:SetTheme(name)
    if Themes[name] then self._Theme=Themes[name]
    elseif type(name)=="table" then self._Theme=name end
end
function CrozoX:SetLanguage(name)
    local l=Languages[name]
    if l then self._Lang=l;self._LangName=name
        self:SetTheme(name=="Arabic" and "Red" or "Blue") end
end

