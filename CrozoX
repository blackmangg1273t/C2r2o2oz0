-- ============================================================
--  ENTRY POINT
-- ============================================================
local function Init()
    local lib=setmetatable({},CrozoX)
    lib._Theme=Themes.Blue; lib._Lang=Languages.English
    lib._LangName="English"; lib._Windows={}
    lib._NotifCount=0; lib._ConfigData={}
    lib:_Init()
    local sg=lib._ScreenGui

    local API={}; API.Lang=Languages; API.Icons=Icons; API.Fonts=FONTS

    function API:CreateWindow(cfg)
        if type(cfg)=="string" then cfg={Title=cfg} end
        if API._langSelected then
            return lib:CreateWindow(cfg)
        end
        API._pendingWindowCfg = cfg
        local proxy = {
            _realWindow = nil,
            _tabsQueue  = {},
        }
        API._windowProxy = proxy
        setmetatable(proxy, {
            __index = function(t, k)
                if t._realWindow then return t._realWindow[k] end
                return function(self2, ...)
                    table.insert(t._tabsQueue, {k, {...}})
                end
            end,
            __call = function(t, c)
                if t._realWindow then return t._realWindow(c) end
                if type(c)=="string" then c={Name=c} end
                table.insert(t._tabsQueue, {"CreateTab", {c}})
            end,
        })
        return proxy
    end
    function API:SetTheme(n)    lib:SetTheme(n)      end
    function API:SetLanguage(n) lib:SetLanguage(n)   end
    function API:Notify(cfg)    lib:Notify(cfg)       end
    function API:SaveConfig(n)  lib:SaveConfig(n)     end
    function API:LoadConfig(n)  return lib:LoadConfig(n) end
    function API:GetTheme()     return lib._Theme     end
    function API:GetLang()      return lib._Lang      end
    function API:GetLangName()  return lib._LangName  end

    setmetatable(API,{__call=function(_,cfg)
        if type(cfg)=="string" then
            if Themes[cfg] then lib:SetTheme(cfg);return API end
            return lib:CreateWindow({Title=cfg})
        elseif type(cfg)=="table" then return lib:CreateWindow(cfg) end
    end})

    API._langSelected = false

    PlayIntro(sg, function()
        ShowLangSelect(sg, function(langName)
            lib:SetLanguage(langName)
            API._langSelected = true
            lib:Notify({
                Title    = langName=="Arabic" and "ŔÖōĪō≠ō®ōßŔč ō®ŔÉ ŔĀŔä CrozoX" or "Welcome to CrozoX",
                Text     = langName=="Arabic"
                    and "ō™ŔÖ ō™ō≠ŔÖŔäŔĄ ōßŔĄŔÖŔÉō™ō®ō© ō®ŔÜō¨ōßō≠ ‚úď"
                    or  "Library loaded successfully ‚úď",
                Duration = 5,
                Type     = "Success",
            })

            if API._pendingWindowCfg then
                local cfg = API._pendingWindowCfg
                API._pendingWindowCfg = nil
                local window = lib:CreateWindow(cfg)

                if API._windowProxy and API._windowProxy._tabsQueue then
                    for _, call in ipairs(API._windowProxy._tabsQueue) do
                        local methodName, args = call[1], call[2]
                        if methodName == "CreateTab" then
                            window:CreateTab(unpack(args))
                        elseif window[methodName] then
                            window[methodName](window, unpack(args))
                        end
                    end
                    API._windowProxy._realWindow = window
                end
            end

            if API._pendingWindow then
                local fn = API._pendingWindow
                API._pendingWindow = nil
                task.spawn(fn)
            end
        end)
    end)

    return API
end

return Init()
