        -- ── Toggle ─────────────────────────────────────────
        function Tab:AddToggle(tcfg)
            tcfg=tcfg or {}
            local name    =tcfg.Name or "Toggle"
            local desc    =tcfg.Description or ""
            local val     =tcfg.Default or false
            local callback=tcfg.Callback or function() end
            local h=desc~="" and 60 or 46
            local f=EF(h)
            EL(f,name,12,desc~="" and 10 or 13,240,20,T.Text,L.FontSemi,L.LabelSize)
            if desc~="" then EL(f,desc,12,32,240,16,T.TextMuted,L.FontBody,12) end

            local track=New("Frame",{Size=UDim2.new(0,50,0,28),
                Position=UDim2.new(1,-62,0.5,-14),
                BackgroundColor3=val and T.Primary or T.Border,
                BorderSizePixel=0,ZIndex=14,Parent=f})
            Corner(track,14)
            local knob=New("Frame",{Size=UDim2.new(0,22,0,22),
                Position=val and UDim2.new(1,-25,0.5,-11) or UDim2.new(0,3,0.5,-11),
                BackgroundColor3=Color3.new(1,1,1),BorderSizePixel=0,
                ZIndex=15,Parent=track})
            Corner(knob,11)
            -- shadow on knob
            New("ImageLabel",{Size=UDim2.new(1,6,1,6),Position=UDim2.new(0,-3,0,-2),
                BackgroundTransparency=1,Image="rbxassetid://6014261993",
                ImageColor3=Color3.fromRGB(0,0,0),ImageTransparency=0.7,
                ScaleType=Enum.ScaleType.Slice,SliceCenter=Rect.new(49,49,450,450),
                ZIndex=14,Parent=knob})

            local ca=New("TextButton",{Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,Text="",ZIndex=16,Parent=f})
            local El={Value=val}
            local function SetVal(v,fire)
                val=v;El.Value=v
                Tween(track,{BackgroundColor3=v and T.Primary or T.Border},0.22)
                -- Back easing على الـ knob يعطي bounce حيوي
                Tween(knob,{Position=v
                    and UDim2.new(1,-25,0.5,-11)
                    or  UDim2.new(0,3,0.5,-11)},0.28,Enum.EasingStyle.Back)
                -- Gradient عند التفعيل
                local g=track:FindFirstChildWhichIsA("UIGradient")
                if v and not g then
                    New("UIGradient",{Color=ColorSequence.new{
                        ColorSequenceKeypoint.new(0,T.Primary),
                        ColorSequenceKeypoint.new(1,T.PrimaryLight),
                    },Parent=track})
                elseif not v and g then
                    g:Destroy()
                end
                if fire~=false then Safe(callback,v) end
            end
            ca.MouseButton1Click:Connect(function() SetVal(not val) end)
            function El:Set(v) SetVal(v,true) end
            function El:Get() return val end
            return El
        end

