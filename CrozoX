            EL(f,name,12,desc~="" and 10 or 13,240,20,T.Text,L.FontSemi,L.LabelSize)
            if desc~="" then EL(f,desc,12,32,240,16,T.TextMuted,L.FontBody,12) end

            local track=New("Frame",{Size=UDim2.new(0,50,0,28),
                Position=UDim2.new(1,-62,0.5,-14),
                BackgroundColor3=val and T.Primary or T.Border,
                BorderSizePixel=0,ZIndex=14,Parent=f})
            Corner(track,14)
            local knob=New("Frame",{Size=UDim2.new(0,22,0,22),
                Position=val and UDim2.new(1,-25,0.5,-11) or UDim2.new(0,3,0.5,-11),
                BackgroundColor3=Color3.new(1,1,1),BorderSizePixel=0,
                ZIndex=15,Parent=track})
            Corner(knob,11)
            -- shadow on knob
            New("ImageLabel",{Size=UDim2.new(1,6,1,6),Position=UDim2.new(0,-3,0,-2),
                BackgroundTransparency=1,Image="rbxassetid://6014261993",
                ImageColor3=Color3.fromRGB(0,0,0),ImageTransparency=0.7,
                ScaleType=Enum.ScaleType.Slice,SliceCenter=Rect.new(49,49,450,450),
                ZIndex=14,Parent=knob})

            local ca=New("TextButton",{Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,Text="",ZIndex=16,Parent=f})
            local El={Value=val}
            local function SetVal(v,fire)
                val=v;El.Value=v
                Tween(track,{BackgroundColor3=v and T.Primary or T.Border},0.22)
                -- Back easing على الـ knob يعطي bounce حيوي
                Tween(knob,{Position=v
                    and UDim2.new(1,-25,0.5,-11)
                    or  UDim2.new(0,3,0.5,-11)},0.28,Enum.EasingStyle.Back)
                -- Gradient عند التفعيل
                local g=track:FindFirstChildWhichIsA("UIGradient")
                if v and not g then
                    New("UIGradient",{Color=ColorSequence.new{
                        ColorSequenceKeypoint.new(0,T.Primary),
                        ColorSequenceKeypoint.new(1,T.PrimaryLight),
                    },Parent=track})
                elseif not v and g then
                    g:Destroy()
                end
                if fire~=false then Safe(callback,v) end
            end
            ca.MouseButton1Click:Connect(function() SetVal(not val) end)
            function El:Set(v) SetVal(v,true) end
            function El:Get() return val end
            return El
        end

        -- ── Slider ─────────────────────────────────────────
        function Tab:AddSlider(scfg)
            scfg=scfg or {}
            local name=scfg.Name or "Slider"
            local min =scfg.Min  or 0
            local max =scfg.Max  or 100
            local def =math.clamp(scfg.Default or min,min,max)
            local suf =scfg.Suffix or ""
            local cb  =scfg.Callback or function() end
            local val =def
            local f=EF(66)
            EL(f,name,12,10,220,20,T.Text,L.FontSemi,L.LabelSize)
            local vl=New("TextLabel",{Size=UDim2.new(0,88,0,20),
                Position=UDim2.new(1,-100,0,10),BackgroundTransparency=1,
                Text=tostring(val)..suf,TextColor3=T.Primary,
                Font=Enum.Font.GothamBold,TextSize=L.LabelSize,
                TextXAlignment=Enum.TextXAlignment.Right,ZIndex=14,Parent=f})
            local tbg=New("Frame",{Size=UDim2.new(1,-24,0,6),
                Position=UDim2.new(0,12,0,48),BackgroundColor3=T.Border,
                BorderSizePixel=0,ZIndex=14,Parent=f})
            Corner(tbg,3)
            local fill=New("Frame",{Size=UDim2.new((val-min)/(max-min),0,1,0),
                BackgroundColor3=T.Primary,BorderSizePixel=0,ZIndex=15,Parent=tbg})
            Corner(fill,3)
            -- gradient on fill
            local fillGrad=New("UIGradient",{Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,T.PrimaryLight),
                ColorSequenceKeypoint.new(1,T.Primary)},Parent=fill})
            local knob=New("Frame",{Size=UDim2.new(0,16,0,16),
                Position=UDim2.new((val-min)/(max-min),-8,0.5,-8),
                BackgroundColor3=Color3.new(1,1,1),BorderSizePixel=0,
                ZIndex=16,Parent=tbg})
            Corner(knob,8)
            -- UIStroke Transparency 0.6 حول الـ knob
            New("UIStroke", {
                Color        = T.Primary,
                Thickness    = 2,
                Transparency = 0.6,
                Parent       = knob,
            })
            New("ImageLabel",{Size=UDim2.new(1,14,1,14),
                Position=UDim2.new(0,-7,0,-5),
                BackgroundTransparency=1,
                Image="rbxassetid://6014261993",
                ImageColor3=T.PrimaryGlow,
                ImageTransparency=0.82,
                ScaleType=Enum.ScaleType.Slice,
                SliceCenter=Rect.new(49,49,450,450),
                ZIndex=15,Parent=knob})
            local drag=false
            local cz=New("TextButton",{Size=UDim2.new(1,0,0,34),
                Position=UDim2.new(0,0,0,34),BackgroundTransparency=1,
                Text="",ZIndex=17,Parent=f})
            cz.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
            end)
            cz.InputEnded:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
            end)
            local El={Value=val}
            local function SV(v,fire)
                v=math.clamp(math.floor(v+0.5),min,max);val=v;El.Value=v
                local p=(v-min)/(max-min)
                Tween(fill,{Size=UDim2.new(p,0,1,0)},0.05)
                Tween(knob,{Position=UDim2.new(p,-8,0.5,-8)},0.05)
                vl.Text=tostring(v)..suf
                if fire~=false then Safe(cb,v) end
            end
            UserInputService.InputChanged:Connect(function(inp)
                if drag and inp.UserInputType==Enum.UserInputType.MouseMovement then
                    local p=math.clamp((inp.Position.X-tbg.AbsolutePosition.X)
                        /tbg.AbsoluteSize.X,0,1)
                    SV(min+p*(max-min))
                end
            end)
            function El:Set(v) SV(v,true) end
            function El:Get() return val end
            return El
        end

        -- ── Dropdown ── يُزيح العناصر بدلاً من الفتح فوقها ──
        function Tab:AddDropdown(dcfg)
            dcfg=dcfg or {}
            local name=dcfg.Name or "Dropdown"
            local opts=dcfg.Options or {}
            local sel =dcfg.Default or opts[1]
            local cb  =dcfg.Callback or function() end
            local open=false

            -- حاوية خارجية: تتمدد عند الفتح وتزيح ما تحتها
            local container=New("Frame",{
                Size=UDim2.new(1,0,0,46),   -- يبدأ بحجم الزر فقط
                BackgroundTransparency=1,
                BorderSizePixel=0,
                ZIndex=13, Parent=tabPage,
            })

            -- الزر الرئيسي (header)
            local f=New("Frame",{
                Size=UDim2.new(1,0,0,46),
                BackgroundColor3=T.SurfaceAlt,
                BorderSizePixel=0, ZIndex=13, Parent=container,
            })
            Corner(f,12); Stroke(f,T.Border,1,0)
            -- Shadow
            New("ImageLabel",{Size=UDim2.new(1,10,1,10),
                Position=UDim2.new(0,-5,0,2),BackgroundTransparency=1,
                Image="rbxassetid://6014261993",ImageColor3=Color3.fromRGB(0,0,0),
                ImageTransparency=0.88,ScaleType=Enum.ScaleType.Slice,
                SliceCenter=Rect.new(49,49,450,450),ZIndex=12,Parent=f})

            EL(f,name,12,13,185,20,T.Text,L.FontSemi,L.LabelSize)
            local sl=New("TextLabel",{Size=UDim2.new(0,110,0,20),
                Position=UDim2.new(1,-145,0,13),BackgroundTransparency=1,
                Text=tostring(sel or "—"),TextColor3=T.Primary,
                Font=L.FontBody,TextSize=L.LabelSize,
                TextXAlignment=Enum.TextXAlignment.Right,ZIndex=14,Parent=f})

            -- Arrow icon
            local arrowFrame=New("Frame",{Size=UDim2.new(0,22,0,22),
                AnchorPoint=Vector2.new(1,0.5),
                Position=UDim2.new(1,-8,0.5,0),
                BackgroundColor3=T.SurfaceHover,
                BorderSizePixel=0,ZIndex=14,Parent=f})
            Corner(arrowFrame,6)
            local aIco=Img(arrowFrame,Icons.chevrondown,12,
                UDim2.new(0.5,-6,0.5,-6),T.TextDim,15)

            -- قائمة الخيارات — داخل نفس الـ container مباشرة
            local dl=New("Frame",{
                Size=UDim2.new(1,0,0,0),        -- يبدأ بصفر
                Position=UDim2.new(0,0,0,50),   -- تحت الـ header مباشرة
                BackgroundColor3=T.Surface,
                BorderSizePixel=0,
                ClipsDescendants=true,
                ZIndex=14, Parent=container,
            })
            Corner(dl,10)
            Stroke(dl,T.BorderBright,1,0.3)
            ListLayout(dl,2); Pad(dl,4,4,4,4)

            local ROW_H = 32
            local El={Value=sel}

            local function SetSel(o)
                sel=o; El.Value=o; sl.Text=tostring(o); Safe(cb,o)
            end

            local function Refresh()
                for _,c in ipairs(dl:GetChildren()) do
                    if c:IsA("Frame") then c:Destroy() end
                end
                for _,o in ipairs(opts) do
                    local isA=(o==sel)
                    local row=New("Frame",{Size=UDim2.new(1,0,0,ROW_H),
                        BackgroundColor3=isA and T.SurfaceHover or T.SurfaceAlt,
                        BorderSizePixel=0,ZIndex=15,Parent=dl})
                    Corner(row,7)
                    -- Active indicator
                    if isA then
                        local ind=New("Frame",{Size=UDim2.new(0,3,0.6,0),
                            Position=UDim2.new(0,0,0.2,0),
                            BackgroundColor3=T.Primary,BorderSizePixel=0,
                            ZIndex=16,Parent=row})
                        Corner(ind,2)
                    end
                    EL(row,tostring(o),10,0,200,ROW_H,
                        isA and T.Text or T.TextDim,
                        isA and L.FontSemi or L.FontBody,L.LabelSize,16)
                    local rb=New("TextButton",{Size=UDim2.new(1,0,1,0),
                        BackgroundTransparency=1,Text="",ZIndex=17,Parent=row})
                    rb.MouseEnter:Connect(function()
                        if o~=sel then Tween(row,{BackgroundColor3=T.SurfaceHover},0.1) end
                    end)
                    rb.MouseLeave:Connect(function()
                        if o~=sel then Tween(row,{BackgroundColor3=T.SurfaceAlt},0.1) end
                    end)
                    rb.MouseButton1Click:Connect(function()
                        SetSel(o)
                        -- إغلاق مع انيميشن
                        open=false
                        local targetH=46
                        Tween(container,{Size=UDim2.new(1,0,0,targetH)},
                            0.28,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                        Tween(dl,{Size=UDim2.new(1,0,0,0)},
                            0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                        Tween(aIco,{Rotation=0},0.2)
                        Tween(arrowFrame,{BackgroundColor3=T.SurfaceHover},0.2)
                        Tween(f,{BackgroundColor3=T.SurfaceAlt},0.2)
                    end)
                end
            end
            Refresh()

            -- تحديث الـ layout عند تغيير canvas
            local dlLayout=dl:FindFirstChildWhichIsA("UIListLayout")
            if dlLayout then
                dlLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    if open then
                        dl.CanvasSize=UDim2.new(0,0,0,dlLayout.AbsoluteContentSize.Y+8)
                    end
                end)
            end

            local tog=New("TextButton",{Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,Text="",ZIndex=15,Parent=f})

            tog.MouseButton1Click:Connect(function()
                open=not open
                Refresh()
                if open then
                    -- حساب الارتفاع المناسب
                    local listH=math.min(#opts*ROW_H+8,200)
                    local totalH=46+4+listH   -- header + gap + list

                    -- 1. container يتمدد → يزيح العناصر تحته تلقائياً (UIListLayout)
                    Tween(container,{Size=UDim2.new(1,0,0,totalH)},
                        0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
                    -- 2. القائمة تظهر من الأعلى للأسفل
                    Tween(dl,{Size=UDim2.new(1,0,0,listH)},
                        0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
                    -- 3. Header يضيء
                    Tween(f,{BackgroundColor3=T.SurfaceHover},0.2)
                    -- 4. Arrow يدور
                    Tween(aIco,{Rotation=180},0.25,Enum.EasingStyle.Back)
                    Tween(arrowFrame,{BackgroundColor3=T.Border},0.2)
                else
                    -- إغلاق: عكس التمدد
                    Tween(container,{Size=UDim2.new(1,0,0,46)},
                        0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                    Tween(dl,{Size=UDim2.new(1,0,0,0)},
                        0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                    Tween(f,{BackgroundColor3=T.SurfaceAlt},0.2)
                    Tween(aIco,{Rotation=0},0.2)
                    Tween(arrowFrame,{BackgroundColor3=T.SurfaceHover},0.2)
                end
            end)

            -- Hover على الـ header
            tog.MouseEnter:Connect(function()
                if not open then
                    Tween(f,{BackgroundColor3=T.SurfaceHover},0.15) end
            end)
            tog.MouseLeave:Connect(function()
                if not open then
                    Tween(f,{BackgroundColor3=T.SurfaceAlt},0.15) end
            end)

            function El:Set(v) SetSel(v) end
            function El:Get() return sel end
            function El:SetOptions(o) opts=o; Refresh() end
            return El
        end

        -- ── Keybind ────────────────────────────────────────
        function Tab:AddKeybind(kcfg)
            kcfg=kcfg or {}
            local name=kcfg.Name or "Keybind"
            local def =kcfg.Default or Enum.KeyCode.RightControl
            local cb  =kcfg.Callback or function() end
            local cur=def;local listen=false
            local f=EF(46)
            EL(f,name,12,13,230,20,T.Text,L.FontSemi,L.LabelSize)
            local kb=New("TextButton",{Size=UDim2.new(0,100,0,28),
                Position=UDim2.new(1,-112,0.5,-14),BackgroundColor3=T.Background,
                Text=cur.Name,TextColor3=T.Primary,
                Font=Enum.Font.GothamBold,TextSize=12,
                BorderSizePixel=0,ZIndex=14,Parent=f})
            Corner(kb,8);Stroke(kb,T.BorderBright,1,0)
            kb.MouseButton1Click:Connect(function()
                listen=true;kb.Text="···";kb.TextColor3=T.Warning
            end)
            kb.MouseEnter:Connect(function()
                Tween(kb,{BackgroundColor3=T.SurfaceAlt},0.15) end)
            kb.MouseLeave:Connect(function()
                Tween(kb,{BackgroundColor3=T.Background},0.15) end)
            UserInputService.InputBegan:Connect(function(inp,gp)
                if gp then return end
                if listen and inp.UserInputType==Enum.UserInputType.Keyboard then
                    cur=inp.KeyCode;listen=false
                    kb.Text=inp.KeyCode.Name;kb.TextColor3=T.Primary
                    Safe(cb,inp.KeyCode)
                elseif not listen
                    and inp.UserInputType==Enum.UserInputType.Keyboard
                    and inp.KeyCode==cur then Safe(cb,cur) end
            end)
            local El={Value=cur}
            function El:Get() return cur end
            return El
        end

        -- ── Input ──────────────────────────────────────────
        function Tab:AddInput(icfg)
            icfg=icfg or {}
            local name=icfg.Name or "Input"
            local ph  =icfg.Placeholder or "Type here..."
            local def =icfg.Default or ""
            local cb  =icfg.Callback or function() end
            local f=EF(64)
            EL(f,name,12,8,270,20,T.Text,L.FontSemi,L.LabelSize)
            local box=New("TextBox",{Size=UDim2.new(1,-24,0,28),
                Position=UDim2.new(0,12,0,30),BackgroundColor3=T.Background,
                Text=def,PlaceholderText=ph,PlaceholderColor3=T.TextMuted,
                TextColor3=T.Text,Font=L.FontBody,TextSize=L.LabelSize,
                BorderSizePixel=0,ClearTextOnFocus=false,
                TextXAlignment=L.IsRTL and Enum.TextXAlignment.Right or Enum.TextXAlignment.Left,
                ZIndex=14,Parent=f})
            Corner(box,8);Pad(box,0,0,10,10)
            local bs=Stroke(box,T.Border,1,0)
            box.Focused:Connect(function() Tween(bs,{Color=T.Primary},0.15) end)
            box.FocusLost:Connect(function(enter)
                Tween(bs,{Color=T.Border},0.15)
                if enter then Safe(cb,box.Text) end
            end)
            local El={}
            function El:Get() return box.Text end
            function El:Set(v) box.Text=v end
            return El
        end

        -- إذا كان هذا أول تاب، نختاره بعد ما يرجع الـ Tab
        -- بكده نضمن إن العناصر اتضافت قبل الاختيار
        if isFirstTab then
            task.defer(function()
                task.wait()   -- frame واحد يكفي
                SelectTab()
            end)
        end

        return Tab
    end -- CreateTab

    local WAPI={}
    setmetatable(WAPI,{
        __call=function(_,tcfg)
            if type(tcfg)=="string" then tcfg={Name=tcfg} end
            return Window:CreateTab(tcfg)
        end,
        __index=Window,
    })
    function WAPI:CreateTab(c) return Window:CreateTab(c) end
    function WAPI:Toggle()
        if wrapFrame.Visible then
            Tween(mainFrame,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},0.3,
                Enum.EasingStyle.Quart,Enum.EasingDirection.In)
            task.delay(0.32,function() wrapFrame.Visible=false end)
        else
            wrapFrame.Visible=true
            mainFrame.Size=UDim2.new(0.88,0,0.88,0)
            Tween(mainFrame,{Size=UDim2.new(1,0,1,0),BackgroundTransparency=0},
                0.35,Enum.EasingStyle.Back)
        end
    end
    function WAPI:Destroy()
        Tween(mainFrame,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},0.3)
        task.delay(0.35,function() mainFrame:Destroy() end)
    end
    table.insert(self._Windows,WAPI)
    return WAPI
end

-- ============================================================
--  NOTIFICATIONS
-- ============================================================
function CrozoX:Notify(cfg)
    cfg=cfg or {}
    local title=cfg.Title or "Notification"
    local text =cfg.Text  or ""
    local dur  =cfg.Duration or 4
    local ntype=cfg.Type  or "Info"
    local T    =self._Theme
    local L    =self._Lang
    local xAlign=(L and L.IsRTL)
        and Enum.TextXAlignment.Right
        or  Enum.TextXAlignment.Left
    local typeMap={
        Success={color=T.Success,icon=Icons.checkcircle2,bg=T.NotifBgOk},
        Warning={color=T.Warning,icon=Icons.alerttriangle,bg=T.NotifBgWarn},
        Error  ={color=T.Error,  icon=Icons.xcircle,      bg=T.NotifBgErr},
        Info   ={color=T.Primary,icon=Icons.info,          bg=T.NotifBgInfo},
    }
    local td=typeMap[ntype] or typeMap.Info
    local color=td.color
    self._NotifCount=self._NotifCount+1

    -- ── Responsive sizes ──────────────────────────────────
    local _nCam   = workspace.CurrentCamera
    local _nVP    = _nCam and _nCam.ViewportSize or Vector2.new(800,600)
    local _nMin   = math.min(_nVP.X, _nVP.Y)
    local isMob   = (Device.IsMobile or Device.IsTablet) or (_nMin < 500)
    local cardH   = isMob and 72  or 82    -- أكبر شوية للنص
    local panelW  = isMob and 38  or 46
    local iconSz  = isMob and 18  or 22
    local titleSz = isMob and 14  or 14    -- نفس الكمبيوتر
    local bodySz  = isMob and 12  or (L and L.LabelSize or 13)
    local titleY  = isMob and 10  or 13
    local bodyY   = isMob and 30  or 36
    local bodyH   = isMob and 26  or 32
    local txtOffX = isMob and (panelW+8) or 56

    local card=New("Frame",{Name="Notif_"..self._NotifCount,
        Size=UDim2.new(1,0,0,cardH),
        BackgroundColor3=T.Surface,BackgroundTransparency=1,
        BorderSizePixel=0,ZIndex=900,Parent=self._NotifContainer})
    Corner(card, isMob and 9 or 13)
    Stroke(card,color,1,0.5)

    -- Coloured left panel
    local panel=New("Frame",{Size=UDim2.new(0,panelW,1,0),
        BackgroundColor3=td.bg,BorderSizePixel=0,ZIndex=901,Parent=card})
    New("UICorner",{CornerRadius=UDim.new(0, isMob and 9 or 13),Parent=panel})
    New("Frame",{Size=UDim2.new(0,8,1,0),Position=UDim2.new(1,-8,0,0),
        BackgroundColor3=td.bg,BorderSizePixel=0,ZIndex=901,Parent=panel})
    local iconImg=Img(panel,td.icon,iconSz,
        UDim2.new(0.5,-iconSz/2,0.5,-iconSz/2),color,903)
    iconImg.ImageTransparency=1

    local titleLbl=New("TextLabel",{
        Size=UDim2.new(1,-(txtOffX+36),0,18),  -- +36 بدل +20 → مساحة أكبر للـ X
        Position=UDim2.new(0,txtOffX,0,titleY),
        BackgroundTransparency=1,Text=title,TextColor3=T.Text,Font=FONTS.Bold,
        TextSize=titleSz,TextXAlignment=xAlign,TextWrapped=false,
        TextTruncate=Enum.TextTruncate.AtEnd,
        TextTransparency=1,ZIndex=902,Parent=card})
    local bodyLbl=New("TextLabel",{
        Size=UDim2.new(1,-(txtOffX+36),0,bodyH),  -- نفس الـ gap
        Position=UDim2.new(0,txtOffX,0,bodyY),
        BackgroundTransparency=1,Text=text,TextColor3=T.TextDim,
        Font=L and L.FontBody or FONTS.Body,
        TextSize=bodySz,TextXAlignment=xAlign,TextWrapped=true,
        TextTransparency=1,ZIndex=902,Parent=card})

    -- Close X — صغير ومتناسب مع النص
    local xBtnSz = isMob and 20 or 24   -- أصغر على موبايل
    local xBtn=New("TextButton",{Size=UDim2.new(0,xBtnSz,0,xBtnSz),
        Position=UDim2.new(1,-(xBtnSz+5),0,5),
        BackgroundColor3=Color3.fromRGB(40,40,40),
        BackgroundTransparency=isMob and 0.2 or 1,
        Text="",ZIndex=904,Parent=card})
    if isMob then Corner(xBtn, 5) end
    local xIcoSz = isMob and 10 or 12
    local xIco=Img(xBtn,Icons.x,xIcoSz,
        UDim2.new(0.5,-xIcoSz/2,0.5,-xIcoSz/2),T.TextMuted,905)
    xIco.ImageTransparency=1

    -- Progress bar
    local pbg=New("Frame",{Size=UDim2.new(1,-12,0,2),
        Position=UDim2.new(0,6,1,-5),BackgroundColor3=T.Border,
        BorderSizePixel=0,ZIndex=902,Parent=card})
    Corner(pbg,1)
    local pfill=New("Frame",{Size=UDim2.new(1,0,1,0),
        BackgroundColor3=color,BorderSizePixel=0,ZIndex=903,Parent=pbg})
    Corner(pfill,1)
    pfill.BackgroundTransparency=1

    -- Slide من اليمين دايماً (موبايل وPC) — أنظف وأوضح
    local FI = 0.35
    card.Position = UDim2.new(1, 30, 0, 0)
    Tween(card,{BackgroundTransparency=0,Position=UDim2.new(0,0,0,0)},FI,Enum.EasingStyle.Back)
    Tween(iconImg,{ImageTransparency=0},FI)
    Tween(titleLbl,{TextTransparency=0},FI)
    Tween(bodyLbl,{TextTransparency=0},FI)
    Tween(pfill,{BackgroundTransparency=0},FI)
    Tween(xIco,{ImageTransparency=0},FI)
    Tween(pfill,{Size=UDim2.new(0,0,1,0)},dur,Enum.EasingStyle.Linear)

    local dismissed=false
    local function Dismiss()
        if dismissed then return end; dismissed=true
        local FO=0.25
        Tween(card,{BackgroundTransparency=1,Position=UDim2.new(1,30,0,0)},FO,
            Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        Tween(iconImg,{ImageTransparency=1},FO)
        Tween(titleLbl,{TextTransparency=1},FO)
        Tween(bodyLbl,{TextTransparency=1},FO)
        Tween(pfill,{BackgroundTransparency=1},FO)
        Tween(xIco,{ImageTransparency=1},FO)
        task.delay(FO+0.05,function() card:Destroy() end)
    end
    task.delay(dur,Dismiss)
    xBtn.MouseButton1Click:Connect(Dismiss)
    xBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then Dismiss() end
    end)
    local hov=New("TextButton",{Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,Text="",ZIndex=901,Parent=card})
    hov.MouseEnter:Connect(function()
        Tween(card,{BackgroundColor3=T.SurfaceAlt},0.15) end)
    hov.MouseLeave:Connect(function()
        Tween(card,{BackgroundColor3=T.Surface},0.15) end)
end

-- ============================================================
--  CONFIG
-- ============================================================
function CrozoX:SaveConfig(n) SaveCfg(n,self._ConfigData or {}) end
function CrozoX:LoadConfig(n) local d=LoadCfg(n);self._ConfigData=d;return d end

-- ============================================================
--  ENTRY POINT
-- ============================================================
local function Init()
    local lib=setmetatable({},CrozoX)
    lib._Theme=Themes.Blue; lib._Lang=Languages.English
    lib._LangName="English"; lib._Windows={}
    lib._NotifCount=0; lib._ConfigData={}
    lib:_Init()
    local sg=lib._ScreenGui

    local API={}; API.Lang=Languages; API.Icons=Icons; API.Fonts=FONTS

    function API:CreateWindow(cfg)
        if type(cfg)=="string" then cfg={Title=cfg} end
        return lib:CreateWindow(cfg)
    end
    function API:SetTheme(n)    lib:SetTheme(n)      end
    function API:SetLanguage(n) lib:SetLanguage(n)   end
    function API:Notify(cfg)    lib:Notify(cfg)       end
    function API:SaveConfig(n)  lib:SaveConfig(n)     end
    function API:LoadConfig(n)  return lib:LoadConfig(n) end
    function API:GetTheme()     return lib._Theme     end
    function API:GetLang()      return lib._Lang      end
    function API:GetLangName()  return lib._LangName  end

    setmetatable(API,{__call=function(_,cfg)
        if type(cfg)=="string" then
            if Themes[cfg] then lib:SetTheme(cfg);return API end
            return lib:CreateWindow({Title=cfg})
        elseif type(cfg)=="table" then return lib:CreateWindow(cfg) end
    end})

    -- SEQUENCE: Intro → LangSelect → window
    PlayIntro(sg, function()
        ShowLangSelect(sg, function(langName)
            lib:SetLanguage(langName)
            lib:Notify({
                Title    = langName=="Arabic" and "مرحباً بك في CrozoX" or "Welcome to CrozoX",
                Text     = langName=="Arabic"
                    and "تم تحميل المكتبة بنجاح ✓"
                    or  "Library loaded successfully ✓",
                Duration = 5,
                Type     = "Success",
            })
            -- يشغّل الـ callback المسجّل من السكربت الخارجي
            -- API._pendingWindow هو المكان الصح لأن Hub يكتب على API
            if API._pendingWindow then
                local fn = API._pendingWindow
                API._pendingWindow = nil
                task.spawn(fn)
            end
        end)
    end)

    return API
end

return Init()
