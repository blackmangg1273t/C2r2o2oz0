        Tween(tagLabel,{TextTransparency=1},CFG.FadeOut)
        Tween(line,{BackgroundTransparency=1},CFG.FadeOut)
        Tween(loaderBg,{BackgroundTransparency=1},CFG.FadeOut)
        Tween(glowOuter,{ImageTransparency=1},CFG.FadeOut)
        Tween(glowInner,{ImageTransparency=1},CFG.FadeOut)
        Tween(logoHolder,{Size=UDim2.new(0,55,0,55)},CFG.FadeOut,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        TweenWait(bg,{BackgroundTransparency=1},CFG.FadeOut,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
        orbConn:Disconnect()
        task.wait(0.08)
        bg:Destroy()
        if onDone then task.spawn(onDone) end
    end)
end

