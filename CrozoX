        resizing = true
        dragging = false
        local mp = UserInputService:GetMouseLocation()
        rStartX  = mp.X
        rStartY  = mp.Y
        rW       = wrapFrame.AbsoluteSize.X
        rH       = wrapFrame.AbsoluteSize.Y
        rPX      = wrapFrame.AbsolutePosition.X
        rPY      = wrapFrame.AbsolutePosition.Y
    end)

    resizeBtn.MouseEnter:Connect(function()
        Tween(resizeBtn, {BackgroundColor3=T.Primary, BackgroundTransparency=0}, 0.15)
    end)
    resizeBtn.MouseLeave:Connect(function()
        if not resizing then
            Tween(resizeBtn, {BackgroundColor3=T.SurfaceAlt, BackgroundTransparency=0.1}, 0.15)
        end
    end)

    -- ── RenderStepped: drag + resize + resize button pos ──
    RunService.RenderStepped:Connect(function()
        if not wrapFrame.Parent then return end

        -- 1. Drag — يحرك wrapFrame
        if dragging then
            local mp = UserInputService:GetMouseLocation()
            wrapFrame.Position = UDim2.new(0, mp.X - dragOffX, 0, mp.Y - dragOffY)
        end

        -- 2. Resize — يكبر wrapFrame من الزاوية اليمنى السفلى
        if resizing then
            local mp   = UserInputService:GetMouseLocation()
            local newW = math.clamp(rW + (mp.X - rStartX), MIN_W, MAX_W)
            local newH = math.clamp(rH + (mp.Y - rStartY), MIN_H, MAX_H)
            wrapFrame.Size     = UDim2.new(0, newW, 0, newH)
            wrapFrame.Position = UDim2.new(0, rPX, 0, rPY)
            size               = UDim2.new(0, newW, 0, newH)
        end

        -- 3. Resize button — على الحافة المنحنية خارج الزاوية
        local ap = wrapFrame.AbsolutePosition
        local as = wrapFrame.AbsoluteSize
        -- +(-8) عشان يكون على الحافة المنحنية بالضبط
        resizeBtn.Position = UDim2.new(0, ap.X + as.X - 8, 0, ap.Y + as.Y - 8)
    end)

    -- إيقاف resize عند رفع الماوس
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and resizing then
