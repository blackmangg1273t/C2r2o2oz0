    rainbowFrame.Position = UDim2.new(0.5,0,0.62,0)
    card.Position         = UDim2.new(0.5,0,0.62,0)

    Tween(rainbowFrame, {
        BackgroundTransparency = 0,
        Position = UDim2.new(0.5,0,0.5,0),
    }, 0.5, Enum.EasingStyle.Back)
    Tween(card, {
        BackgroundTransparency = 0,
        Position = UDim2.new(0.5,0,0.5,0),
    }, 0.5, Enum.EasingStyle.Back)

    -- ‚ĒÄ‚ĒÄ Confirm ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    confirmBtn.MouseButton1Click:Connect(function()
        Ripple(confirmBtn)

        Tween(overlay,      { BackgroundTransparency=1 }, 0.38)
        Tween(card,         { BackgroundTransparency=1,
