    -- ‚ĒÄ‚ĒÄ FIX: Completely separate touch drag & PC drag ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    -- Touch: pure absolute positioning, no RenderStepped interference
    -- PC: delta-based with smooth lerp in RenderStepped
    local touchDragging = false
    local touchStartX   = 0
    local touchStartY   = 0
    local wrapStartPX   = 0
    local wrapStartPY   = 0

    -- ‚ĒÄ‚ĒÄ FIX: Touch drag uses InputChanged on dragBtn directly ‚ĒÄ‚ĒÄ
    -- This avoids the "freeze mid-drag" caused by UserInputService
    -- InputChanged firing before dragBtn's own InputChanged
    dragBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            if resizing then return end
            local mp = UserInputService:GetMouseLocation()
            lastMouseX = mp.X; lastMouseY = mp.Y
            dragging = true
        elseif inp.UserInputType == Enum.UserInputType.Touch then
            -- FIX: capture position immediately, no hold timer
            touchDragging = true
            dragging      = false  -- prevent RenderStepped delta conflict
            touchStartX   = inp.Position.X
            touchStartY   = inp.Position.Y
            wrapStartPX   = wrapFrame.Position.X.Offset
            wrapStartPY   = wrapFrame.Position.Y.Offset
        end
    end)

    -- FIX: InputChanged on dragBtn itself ‚ÄĒ fires every touch move reliably
    -- Using UserInputService.InputChanged caused "freeze" when touch left button area
    dragBtn.InputChanged:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch and touchDragging then
            local dx = inp.Position.X - touchStartX
            local dy = inp.Position.Y - touchStartY
            -- Apply inverse of UIScale so drag distance matches finger movement
            local sc = wrapFrame:FindFirstChildWhichIsA("UIScale")
            local s  = sc and sc.Scale or 1
            local newX = wrapStartPX + dx / s
            local newY = wrapStartPY + dy / s
            wrapFrame.Position = UDim2.new(0, newX, 0, newY)
            -- Keep smooth vars in sync
            smoothX = newX; smoothY = newY
            dispX   = newX; dispY   = newY
        end
    end)

    dragBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        elseif inp.UserInputType == Enum.UserInputType.Touch then
            touchDragging = false
        end
    end)

    -- FIX: Also catch touch release outside dragBtn (finger slipped off)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        elseif inp.UserInputType == Enum.UserInputType.Touch then
            -- Only clear if we were dragging (not resizing touch)
            if touchDragging then touchDragging = false end
        end
    end)

    -- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
    --  RESIZE BUTTON ‚ÄĒ FIX: Mobile hold-to-resize
    --  FIX: No visual shrink on initial touch.
    --  Only after hold threshold (0.35s) does resize activate.
    --  Visual feedback only starts AFTER hold confirmed.
    -- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
    local rBtnSz = Device.IsPC and 22 or 28

    local resizeBtn = New("TextButton", {
        Name="ResizeBtn",
        Size=UDim2.new(0,rBtnSz,0,rBtnSz),
