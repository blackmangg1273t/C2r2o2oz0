            end
        end)
        clickBtn.MouseLeave:Connect(function()
            if selectedLang ~= langName then
                Tween(frame, {BackgroundColor3=Color3.fromRGB(16,16,20)}, 0.15)
            end
        end)

        btnData[langName] = {
            frame=frame, stroke=fStroke, label=nameLbl, flag=flagLbl,
            dot=dot, color=tc, clickBtn=clickBtn,
        }
        return clickBtn
    end

