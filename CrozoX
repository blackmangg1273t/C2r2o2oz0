        Tween(rainbowFrame, { BackgroundTransparency=1,
            Position=UDim2.new(0.5,0,0.44,0) }, 0.35)

        task.delay(0.42, function()
            rainbowConn:Disconnect()
            overlay:Destroy()
            card:Destroy()
            rainbowFrame:Destroy()
