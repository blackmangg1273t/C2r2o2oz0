-- ── Bootstrap ────────────────────────────────────────────────
function CrozoX:_Init()
    local existing = CoreGui:FindFirstChild("CrozoX")
    if existing then existing:Destroy() end

    local sg = Create("ScreenGui", {
        Name           = "CrozoX",
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 999,
        IgnoreGuiInset = true,
    })
    local ok = SafeCall(function() sg.Parent = CoreGui end)
    if not ok then sg.Parent = LocalPlayer:WaitForChild("PlayerGui") end
    self._ScreenGui = sg

    -- Notification container (bottom-right)
    self._NotifContainer = Create("Frame", {
        Name                 = "NotifContainer",
        Size                 = UDim2.new(0, 330, 1, 0),
        Position             = UDim2.new(1, -345, 0, 0),
        BackgroundTransparency = 1,
        ZIndex               = 900,
        Parent               = sg,
    })
    MakeListLayout(self._NotifContainer, 10, Enum.FillDirection.Vertical,
        Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Bottom)

    return sg
end

function CrozoX:SetTheme(name)
    local t = Themes[name]
    if t then self._Theme = t
    elseif type(name) == "table" then self._Theme = name end
end

function CrozoX:SetLanguage(name)
    local l = Languages[name]
    if l then
        self._Lang     = l
        self._LangName = name
        self:SetTheme(name == "Arabic" and "Red" or "Blue")
    end
end

