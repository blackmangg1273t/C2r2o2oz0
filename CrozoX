            local dl=New("Frame",{
                Size=UDim2.new(1,0,0,0),
                Position=UDim2.new(0,0,0,50),
                BackgroundColor3=T.Surface,
                BorderSizePixel=0,
                ClipsDescendants=true,
                ZIndex=14, Parent=container,
            })
            Corner(dl,10)
            Stroke(dl,T.BorderBright,1,0.3)
            ListLayout(dl,2); Pad(dl,4,4,4,4)

            local ROW_H = 32
            local El={Value=sel}

            local function SetSel(o)
                sel=o; El.Value=o; sl.Text=tostring(o); Safe(cb,o)
            end

            local function Refresh()
                for _,c in ipairs(dl:GetChildren()) do
                    if c:IsA("Frame") then c:Destroy() end
                end
                for _,o in ipairs(opts) do
                    local isA=(o==sel)
                    local row=New("Frame",{Size=UDim2.new(1,0,0,ROW_H),
                        BackgroundColor3=isA and T.SurfaceHover or T.SurfaceAlt,
                        BorderSizePixel=0,ZIndex=15,Parent=dl})
                    Corner(row,7)
                    if isA then
                        local ind=New("Frame",{Size=UDim2.new(0,3,0.6,0),
                            Position=UDim2.new(0,0,0.2,0),
                            BackgroundColor3=T.Primary,BorderSizePixel=0,
                            ZIndex=16,Parent=row})
                        Corner(ind,2)
                    end
                    EL(row,tostring(o),10,0,200,ROW_H,
                        isA and T.Text or T.TextDim,
                        isA and L.FontSemi or L.FontBody,FS.Button,16)
                    local rb=New("TextButton",{Size=UDim2.new(1,0,1,0),
                        BackgroundTransparency=1,Text="",ZIndex=17,Parent=row})
                    rb.MouseEnter:Connect(function()
                        if o~=sel then Tween(row,{BackgroundColor3=T.SurfaceHover},0.1) end
                    end)
                    rb.MouseLeave:Connect(function()
                        if o~=sel then Tween(row,{BackgroundColor3=T.SurfaceAlt},0.1) end
                    end)
                    rb.MouseButton1Click:Connect(function()
                        SetSel(o)
                        open=false
                        Tween(container,{Size=UDim2.new(1,0,0,46)},0.28,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                        Tween(dl,{Size=UDim2.new(1,0,0,0)},0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                        Tween(aIco,{Rotation=0},0.2)
                        Tween(arrowFrame,{BackgroundColor3=T.SurfaceHover},0.2)
                        Tween(f,{BackgroundColor3=T.SurfaceAlt},0.2)
                    end)
                    rb.InputEnded:Connect(function(inp)
                        if inp.UserInputType==Enum.UserInputType.Touch then
                            SetSel(o)
                            open=false
                            Tween(container,{Size=UDim2.new(1,0,0,46)},0.28,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                            Tween(dl,{Size=UDim2.new(1,0,0,0)},0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                            Tween(aIco,{Rotation=0},0.2)
                            Tween(f,{BackgroundColor3=T.SurfaceAlt},0.2)
                        end
                    end)
                end
            end
            Refresh()

            local tog=New("TextButton",{Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,Text="",ZIndex=15,Parent=f})

            local function ToggleDropdown()
                open=not open
                Refresh()
                if open then
                    local listH=math.min(#opts*ROW_H+8,200)
                    local totalH=46+4+listH
                    Tween(container,{Size=UDim2.new(1,0,0,totalH)},0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
                    Tween(dl,{Size=UDim2.new(1,0,0,listH)},0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
                    Tween(f,{BackgroundColor3=T.SurfaceHover},0.2)
                    Tween(aIco,{Rotation=180},0.25,Enum.EasingStyle.Back)
                    Tween(arrowFrame,{BackgroundColor3=T.Border},0.2)
                else
                    Tween(container,{Size=UDim2.new(1,0,0,46)},0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                    Tween(dl,{Size=UDim2.new(1,0,0,0)},0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                    Tween(f,{BackgroundColor3=T.SurfaceAlt},0.2)
                    Tween(aIco,{Rotation=0},0.2)
                    Tween(arrowFrame,{BackgroundColor3=T.SurfaceHover},0.2)
                end
            end

            tog.MouseButton1Click:Connect(ToggleDropdown)
            tog.InputEnded:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.Touch then ToggleDropdown() end
            end)
            tog.MouseEnter:Connect(function()
                if not open then Tween(f,{BackgroundColor3=T.SurfaceHover},0.15) end
            end)
            tog.MouseLeave:Connect(function()
                if not open then Tween(f,{BackgroundColor3=T.SurfaceAlt},0.15) end
            end)

            function El:Set(v) SetSel(v) end
            function El:Get() return sel end
            function El:SetOptions(o) opts=o; Refresh() end
            return El
        end

