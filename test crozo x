-- ── Import ───────────────────────────────────────────────────
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/blackmangg1273t/C2r2o2oz0/refs/heads/main/CrozoX"))()

-- ── OPTIONAL: Override language/theme before window opens ──
-- Library:SetLanguage("Arabic")  -- Also sets theme to Red
-- Library:SetTheme("Purple")     -- Manual override

-- ── Create main window ───────────────────────────────────────
local Window = Library:CreateWindow({
    Title    = "CrozoX Hub",
    Subtitle = "v1.0.0 | Universal",
    Size     = UDim2.new(0, 620, 0, 440),
})

-- ── MAIN TAB ─────────────────────────────────────────────────
local Main = Window:CreateTab({ Name = "Main", Icon = "⚡" })

Main:AddSection("Combat")

local AutoFarmToggle = Main:AddToggle({
    Name     = Library:GetLang().AutoFarm,
    Default  = false,
    Callback = function(value)
        -- your logic here
        Library:Notify({
            Title = "Auto Farm",
            Text  = value and "Enabled!" or "Disabled!",
            Type  = value and "Success" or "Warning",
            Duration = 3,
        })
    end,
})

Main:AddButton({
    Name        = "Kill All Enemies",
    Description = "Eliminates all enemies in the map",
    Callback    = function()
        Library:Notify({ Title = "Action", Text = "Killing all enemies...", Type = "Info", Duration = 2 })
    end,
})

Main:AddSection("Movement")

local SpeedSlider = Main:AddSlider({
    Name     = Library:GetLang().Speed,
    Min      = 16,
    Max      = 500,
    Default  = 16,
    Suffix   = " studs/s",
    Callback = function(value)
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = value
        end
    end,
})

Main:AddSlider({
    Name     = "Jump Height",
    Min      = 7,
    Max      = 200,
    Default  = 7,
    Suffix   = " studs",
    Callback = function(value)
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.JumpPower = value
        end
    end,
})

-- ── PLAYER TAB ───────────────────────────────────────────────
local Player = Window:CreateTab({ Name = "Player", Icon = "👤" })

Player:AddSection("Appearance")

Player:AddToggle({
    Name     = "God Mode",
    Default  = false,
    Callback = function(value)
        -- Anti-damage logic
    end,
})

Player:AddToggle({
    Name     = "Infinite Jump",
    Default  = false,
    Callback = function(value)
        -- Infinite jump logic
    end,
})

Player:AddColorPicker({
    Name     = "Character Color",
    Default  = Color3.fromRGB(255, 255, 255),
    Callback = function(color)
        -- Apply color to character
    end,
})

Player:AddSection("Misc")

Player:AddInput({
    Name        = "Custom Name",
    Placeholder = "Enter display name...",
    Callback    = function(text)
        Library:Notify({ Title = "Name Changed", Text = text, Type = "Success", Duration = 3 })
    end,
})

-- ── WORLD TAB ────────────────────────────────────────────────
local World = Window:CreateTab({ Name = "World", Icon = "🌐" })

World:AddSection("Environment")

World:AddSlider({
    Name     = "Time of Day",
    Min      = 0,
    Max      = 24,
    Default  = 12,
    Callback = function(value)
        game:GetService("Lighting").TimeOfDay = value .. ":00:00"
    end,
})

World:AddToggle({
    Name     = "No Fog",
    Default  = false,
    Callback = function(v)
        game:GetService("Lighting").FogEnd = v and 1e9 or 100000
    end,
})

World:AddDropdown({
    Name     = Library:GetLang().SelectEnemy,
    Options  = { "Enemy1", "Enemy2", "Enemy3", "Boss", "Mini-Boss" },
    Default  = "Enemy1",
    Callback = function(option)
        Library:Notify({ Title = "Target Selected", Text = option, Type = "Info", Duration = 2 })
    end,
})

-- ── SETTINGS TAB ─────────────────────────────────────────────
local Settings = Window:CreateTab({ Name = "Settings", Icon = "⚙" })

Settings:AddSection("Theme")

Settings:AddDropdown({
    Name     = "Color Theme",
    Options  = { "Blue", "Red", "Green", "Purple" },
    Default  = "Blue",
    Callback = function(theme)
        Library:SetTheme(theme)
        Library:Notify({ Title = "Theme", Text = theme .. " theme applied!", Type = "Success", Duration = 3 })
    end,
})

Settings:AddSection("Keybinds")

Settings:AddKeybind({
    Name     = Library:GetLang().ToggleUI,
    Default  = Enum.KeyCode.RightControl,
    Callback = function(key)
        Window:Toggle()
    end,
})

Settings:AddSection("Config")

Settings:AddButton({
    Name     = Library:GetLang().SaveConfig,
    Callback = function()
        Library:SaveConfig("default")
        Library:Notify({ Title = "Config", Text = "Settings saved!", Type = "Success", Duration = 3 })
    end,
})

Settings:AddButton({
    Name     = Library:GetLang().LoadConfig,
    Callback = function()
        Library:LoadConfig("default")
        Library:Notify({ Title = "Config", Text = "Settings loaded!", Type = "Info", Duration = 3 })
    end,
})

