local url = "https://raw.githubusercontent.com/blackmangg1273t/C2r2o2oz0/main/CrozoX?cacheBust=" .. tostring(os.time())
local CrozoX = loadstring(game:HttpGet(url))()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function GetHumanoid()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return character:FindFirstChildOfClass("Humanoid")
end

local Window = CrozoX:CreateWindow({
    Title    = "CrozoX Hub",
    Subtitle = "v7.0.0 | Universal",
    Logo     = "rbxassetid://93116857865430",
    Size     = UDim2.new(0, 660, 0, 470),
})

local MainTab   = Window:CreateTab({ Name = "Main",   Icon = "home" })
local FarmTab   = Window:CreateTab({ Name = "Farm",   Icon = "sprout" })
local PlayerTab = Window:CreateTab({ Name = "Player", Icon = "user" })
local MiscTab   = Window:CreateTab({ Name = "Misc",   Icon = "settings" })

-- ═══════════════════════════════════════════════════════════════
--  Main Tab
-- ═══════════════════════════════════════════════════════════════

MainTab:AddSection("General")

MainTab:AddToggle({
    Name = "Auto Farm",
    Description = "يقوم بالزراعة التلقائية",
    Default = false,
    Callback = function(value)
        print("Auto Farm:", value)

        CrozoX:Notify({
            Title = "Auto Farm",
            Text = value and "تم تفعيل الزراعة التلقائية" or "تم إيقاف الزراعة التلقائية",
            Type = value and "Success" or "Info",
            Duration = 3
        })
    end
})

MainTab:AddButton({
    Name = "Collect All",
    Description = "يجمع كل الموارد في الخريطة",
    Icon = "package",
    Callback = function()
        CrozoX:Notify({
            Title = "Collect",
            Text = "تم جمع جميع الموارد!",
            Type = "Info",
            Duration = 3
        })
    end
})

MainTab:AddSlider({
    Name = "Walk Speed",
    Min = 16,
    Max = 200,
    Default = 16,
    Suffix = " Studs/s",
    Callback = function(value)
        local humanoid = GetHumanoid()
        if humanoid then
            humanoid.WalkSpeed = value
        end
    end
})

-- ═══════════════════════════════════════════════════════════════
--  Farm Tab
-- ═══════════════════════════════════════════════════════════════

FarmTab:AddSection("Farming Options")

FarmTab:AddDropdown({
    Name = "Select Enemy",
    Options = {"Bandit", "Thug", "Boss", "Mini-Boss"},
    Default = "Bandit",
    Callback = function(selected)
        print("Selected enemy:", selected)

        CrozoX:Notify({
            Title = "Enemy Selected",
            Text = "Selected: " .. tostring(selected),
            Type = "Info",
            Duration = 2
        })
    end
})

FarmTab:AddInput({
    Name = "Farm Delay",
    Placeholder = "Enter seconds...",
    Default = "1.5",
    Callback = function(text)
        print("Farm delay set to:", text)
    end
})

-- ═══════════════════════════════════════════════════════════════
--  Player Tab
-- ═══════════════════════════════════════════════════════════════

PlayerTab:AddSection("Character")

PlayerTab:AddSlider({
    Name = "Jump Power",
    Min = 50,
    Max = 300,
    Default = 50,
    Suffix = " Power",
    Callback = function(value)
        local humanoid = GetHumanoid()
        if humanoid then
            humanoid.UseJumpPower = true
            humanoid.JumpPower = value
        end
    end
})

PlayerTab:AddKeybind({
    Name = "Toggle UI Key",
    Default = Enum.KeyCode.RightControl,
    Callback = function()
        Window:Toggle()
    end
})

-- ═══════════════════════════════════════════════════════════════
--  Misc Tab
-- ═══════════════════════════════════════════════════════════════

MiscTab:AddSection("Settings")

MiscTab:AddButton({
    Name = "Save Config",
    Description = "يحفظ إعداداتك الحالية",
    Icon = "save",
    Callback = function()
        CrozoX:SaveConfig("MyConfig")

        CrozoX:Notify({
            Title = "Config",
            Text = "تم حفظ الإعدادات بنجاح",
            Type = "Success",
            Duration = 3
        })
    end
})

MiscTab:AddButton({
    Name = "Load Config",
    Description = "يحمل آخر إعدادات محفوظة",
    Icon = "download",
    Callback = function()
        CrozoX:LoadConfig("MyConfig")

        CrozoX:Notify({
            Title = "Config",
            Text = "تم تحميل الإعدادات",
            Type = "Info",
            Duration = 3
        })
    end
})
