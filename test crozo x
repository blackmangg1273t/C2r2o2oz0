Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer or not playerAlertsEnabled then
        return
    end

    NotifyPlayer("playerJoinedTitle", FormatMsg("playerJoinedText", PlayerLabel(player)), player, "Success", true)

    if PlayerSelector and PlayerSelector.Refresh then
        PlayerSelector:Refresh()
    end
end)

Players.PlayerRemoving:Connect(function(player)
    if player == LocalPlayer or not playerAlertsEnabled then
        return
    end

    NotifyPlayer("playerLeftTitle", FormatMsg("playerLeftText", PlayerLabel(player)), player, "Warning", true)
end)

