local function IsArabic()
    local ok, langName = pcall(function()
        return CrozoX:GetLangName()
    end)

    return ok and langName == "Arabic"
end

local function Msg(key)
    local lang = IsArabic() and Messages.Arabic or Messages.English
    return lang[key] or Messages.English[key] or key
end

local function FormatMsg(key, ...)
    return string.format(Msg(key), ...)
end

local function GetHumanoid()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return character:FindFirstChildOfClass("Humanoid")
end

local function PlayerLabel(player)
    if not player then
        return Msg("noPlayer")
    end

    return string.format("%s (@%s)", player.DisplayName or player.Name, player.Name)
end

local function Notify(titleKey, textKey, notifType, playSound, ...)
    CrozoX:Notify({
        Title = Msg(titleKey),
        Text = FormatMsg(textKey, ...),
        Type = notifType or "Info",
        Duration = 4,
        Sound = playSound ~= false,
    })
end

local function NotifyPlayer(titleKey, text, player, notifType, playSound)
    CrozoX:Notify({
        Title = Msg(titleKey),
        Text = text,
        Type = notifType or "Info",
        Duration = 4,
        UserId = player and player.UserId or nil,
        Sound = playSound ~= false,
    })
end

