local PlayerSelector = PlayerTab:AddPlayerDropdown({
    Name = "Select Player",
    IncludeLocal = false,
    Callback = function(player)
        selectedPlayer = player

        if player then
            NotifyPlayer("playerSelectedTitle", FormatMsg("playerSelectedText", PlayerLabel(player)), player, "Info", false)
        end
    end,
})

PlayerTab:AddButton({
    Name = "Teleport To Player",
    Description = "Moves your character near the selected player",
    Icon = "map",
    Callback = function()
        if not selectedPlayer then
            Notify("selectFirstTitle", "selectFirstText", "Warning", true)
            return
        end

        local targetRoot = selectedPlayer.Character and selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

        if targetRoot and character then
            character:PivotTo(targetRoot.CFrame + Vector3.new(0, 3, 0))
            NotifyPlayer("teleportedTitle", FormatMsg("teleportedText", PlayerLabel(selectedPlayer)), selectedPlayer, "Success", true)
        else
            NotifyPlayer("teleportFailedTitle", FormatMsg("teleportFailedText", PlayerLabel(selectedPlayer)), selectedPlayer, "Warning", true)
        end
    end,
})

PlayerTab:AddButton({
    Name = "Print Player Info",
    Description = "Prints the selected player's identity",
    Icon = "user",
    Callback = function()
        if not selectedPlayer then
            Notify("playerInfoTitle", "selectFirstText", "Warning", true)
            return
        end

        print("Selected Player:", selectedPlayer.DisplayName, selectedPlayer.Name, selectedPlayer.UserId)
        NotifyPlayer("playerInfoTitle", PlayerLabel(selectedPlayer), selectedPlayer, "Info", true)
